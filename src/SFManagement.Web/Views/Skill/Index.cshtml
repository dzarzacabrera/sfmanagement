@model List<SkillDto>

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-brand dark:text-white">Skills Catalogue</h1>
    <a href="/Skill/Create"
       class="bg-brand dark:bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep dark:hover:bg-brand-deep">
        + New Skill
    </a>
</div>

<div class="flex mb-6">
    <div class="flex items-stretch flex-1">
        <div class="relative flex-1 min-w-0">
            <input type="text" id="skillSearch"
                   class="w-full border border-gray-300 rounded-lg xl:rounded-l-lg xl:rounded-tr-none xl:rounded-br-none px-4 py-2.5 pr-8 text-sm focus-visible:outline-none focus-visible:border-blue-500 focus-visible:ring-4 focus-visible:ring-[#96c0d9] dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100 dark:placeholder-gray-400"
                   placeholder="Search skills...">
            <button type="button" id="clearSearch"
                    class="hidden absolute right-2 top-1/2 -translate-y-1/2 p-0.5 rounded text-gray-400 hover:text-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 dark:hover:text-gray-200 transition-colors"
                    aria-label="Clear search">
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
        <div class="hidden xl:flex border border-l-0 border-gray-300 rounded-r-lg overflow-hidden dark:border-gray-600">
            <button type="button" id="viewList"
                    class="p-2.5 transition-colors text-gray-500 hover:bg-gray-50 dark:text-gray-400 dark:hover:bg-gray-700 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9] relative z-10"
                    title="List view">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
            <div class="w-px bg-gray-300 dark:bg-gray-600 shrink-0"></div>
            <button type="button" id="viewCards"
                    class="p-2.5 transition-colors bg-blue-50 text-brand focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9] relative z-10"
                    title="Card view">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                </svg>
            </button>
        </div>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="text-center py-12">
        <p class="text-gray-400 mb-4 dark:text-gray-500">No skills yet.</p>
        <a href="/Skill/Create"
           class="bg-brand text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-brand-deep">
            Add your first skill
        </a>
    </div>
}
else
{
    <div id="skillCards" class="grid gap-4 sm:grid-cols-2 md:grid-cols-2 lg:grid-cols-3">
        @foreach (var skill in Model)
        {
            <div class="skill-card bg-white rounded-xl border border-gray-200 shadow-sm p-5 hover:shadow-md transition-shadow dark:bg-gray-800 dark:border-gray-700 dark:text-gray-100 relative flex flex-col justify-between"
                 data-name="@skill.Name.ToLower()">
                <a href="/Skill/Edit?skillId=@skill.IdEncrypted"
                   class="absolute top-3 right-3 w-10 h-10 flex items-center justify-center rounded-lg text-gray-400 hover:text-brand hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9]"
                   aria-label="Edit @skill.Name">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                    </svg>
                </a>
                <div>
                    <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 pr-12">@skill.Name</h2>
                    <div class="mt-2">
                        @if (skill.IsActive)
                        {
                            <span class="inline-block px-2 py-0.5 rounded-full text-sm sm:text-xs font-medium bg-green-100 text-green-700">Active</span>
                        }
                        else
                        {
                            <span class="inline-block px-2 py-0.5 rounded-full text-sm sm:text-xs font-medium bg-red-100 text-red-700">Inactive</span>
                        }
                    </div>
                </div>
                <div class="flex flex-wrap gap-2 pt-3 justify-end">
                    <a href="/Skill/Detail?skillId=@skill.IdEncrypted"
                       class="border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700 whitespace-nowrap">
                        Detail
                    </a>
                    <form method="post" action="/Skill/ToggleActive" class="inline">
                        <input type="hidden" name="skillIdEncrypted" value="@skill.IdEncrypted">
                        <button type="submit"
                                class="px-3 py-1.5 rounded-lg text-sm font-medium border @(skill.IsActive ? "border-red-300 text-red-600 hover:bg-red-50 dark:border-red-800 dark:hover:bg-red-900/30" : "border-green-300 text-green-600 hover:bg-green-50 dark:border-green-800 dark:hover:bg-green-900/30") whitespace-nowrap">
                            @(skill.IsActive ? "Deactivate" : "Activate")
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>

    <div id="skillList" class="hidden">
        <div class="rounded-xl border border-gray-200 shadow-sm bg-white overflow-hidden dark:bg-gray-800 dark:border-gray-700">
            <div class="grid grid-cols-12 items-center gap-4 py-2.5 px-4 border-b border-gray-100 dark:border-gray-700">
                <div class="col-span-5 text-xs font-semibold text-gray-400 tracking-wider uppercase">Name</div>
                <div class="col-span-3 text-xs font-semibold text-gray-400 tracking-wider uppercase">Status</div>
                <div class="col-span-4 text-xs font-semibold text-gray-400 tracking-wider uppercase text-right">Actions</div>
            </div>
            @foreach (var skill in Model)
            {
                <div class="skill-row grid grid-cols-12 items-center gap-4 border-b border-gray-100 last:border-b-0 py-3 px-4 hover:bg-gray-50 dark:border-gray-700 dark:hover:bg-gray-800 transition-colors cursor-pointer"
                     data-name="@skill.Name.ToLower()"
                     onclick="location.href='/Skill/Detail?skillId=@skill.IdEncrypted'">
                    <div class="col-span-5 font-semibold text-gray-900 dark:text-gray-100 text-sm truncate">
                        @skill.Name
                    </div>
                    <div class="col-span-3 text-sm">
                        @if (skill.IsActive)
                        {
                            <span class="px-2 py-0.5 rounded-full text-sm font-medium bg-green-100 text-green-700">Active</span>
                        }
                        else
                        {
                            <span class="px-2 py-0.5 rounded-full text-sm font-medium bg-red-100 text-red-700">Inactive</span>
                        }
                    </div>
                    <div class="col-span-4 flex items-center justify-end gap-1" onclick="event.stopPropagation()">
                        <a href="/Skill/Detail?skillId=@skill.IdEncrypted"
                           class="p-2 rounded-lg text-blue-400 hover:text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9]"
                           title="View details">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                            </svg>
                        </a>
                        <a href="/Skill/Edit?skillId=@skill.IdEncrypted"
                           class="p-2 rounded-lg text-amber-400 hover:text-amber-600 hover:bg-amber-50 dark:hover:bg-amber-900/20 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9]"
                           title="Edit">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                            </svg>
                        </a>
                        <form method="post" action="/Skill/ToggleActive" class="inline">
                            <input type="hidden" name="skillIdEncrypted" value="@skill.IdEncrypted">
                            <button type="submit"
                                    class="p-2 rounded-lg transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9] @(skill.IsActive ? "text-red-400 hover:text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20" : "text-green-400 hover:text-green-600 hover:bg-green-50 dark:hover:bg-green-900/20")"
                                    title="@(skill.IsActive ? "Deactivate" : "Activate")">
                                @if (skill.IsActive)
                                {
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                }
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>

    <div id="emptyState" class="hidden text-center py-12">
        <p class="text-gray-400 dark:text-gray-500">No skills match your search.</p>
    </div>
}

<script>
    function switchToSkillCards() {
        document.getElementById('skillCards').classList.remove('hidden');
        document.getElementById('skillList').classList.add('hidden');
        document.getElementById('viewCards').className = 'p-2.5 transition-colors bg-blue-50 text-brand';
        document.getElementById('viewList').className = 'p-2.5 transition-colors text-gray-500 hover:bg-gray-50 dark:text-gray-400 dark:hover:bg-gray-700';
        localStorage.setItem('skillViewMode', 'cards');
    }

    function switchToSkillList() {
        document.getElementById('skillCards').classList.add('hidden');
        document.getElementById('skillList').classList.remove('hidden');
        document.getElementById('viewList').className = 'p-2.5 transition-colors bg-blue-50 text-brand';
        document.getElementById('viewCards').className = 'p-2.5 transition-colors text-gray-500 hover:bg-gray-50 dark:text-gray-400 dark:hover:bg-gray-700';
        localStorage.setItem('skillViewMode', 'list');
    }

    var searchInput = document.getElementById('skillSearch');
    var clearBtn = document.getElementById('clearSearch');
    if (searchInput && clearBtn) {
        function toggleClear() {
            clearBtn.classList.toggle('hidden', !searchInput.value);
        }
        searchInput.addEventListener('input', function () {
            var q = this.value.toLowerCase().trim();
            localStorage.setItem('skillSearchQuery', this.value);
            document.querySelectorAll('.skill-card, .skill-row').forEach(function (el) {
                var match = !q || el.dataset.name.includes(q);
                el.style.display = match ? '' : 'none';
            });
            var total = document.querySelectorAll('.skill-card, .skill-row').length;
            var hidden = 0;
            document.querySelectorAll('.skill-card, .skill-row').forEach(function (el) {
                if (el.style.display === 'none') hidden++;
            });
            document.getElementById('emptyState').classList.toggle('hidden', hidden !== total);
            toggleClear();
        });
        clearBtn.addEventListener('click', function () {
            searchInput.value = '';
            localStorage.setItem('skillSearchQuery', '');
            var evt = new Event('input', { bubbles: true });
            searchInput.dispatchEvent(evt);
            searchInput.focus();
        });
    }

    document.getElementById('viewCards')?.addEventListener('click', function () {
        if (document.getElementById('skillCards').classList.contains('hidden')) {
            switchToSkillCards();
        }
    });
    document.getElementById('viewList')?.addEventListener('click', function () {
        if (document.getElementById('skillList').classList.contains('hidden')) {
            switchToSkillList();
        }
    });

    var mql = window.matchMedia('(max-width: 1199px)');
    mql.addEventListener('change', function (e) {
        if (e.matches) {
            if (document.getElementById('skillList') && !document.getElementById('skillList').classList.contains('hidden')) {
                switchToSkillCards();
            }
        }
    });

    var savedView = localStorage.getItem('skillViewMode');
    var savedQuery = localStorage.getItem('skillSearchQuery');

    if (savedView === 'list' && !mql.matches) {
        switchToSkillList();
    } else {
        if (mql.matches) switchToSkillCards();
    }

    if (savedQuery && searchInput) {
        searchInput.value = savedQuery;
        var evt = new Event('input', { bubbles: true });
        searchInput.dispatchEvent(evt);
    }
</script>
