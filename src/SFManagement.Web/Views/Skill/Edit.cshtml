@model SkillDto

<h1 class="text-2xl font-bold pt-2 mb-6 text-brand dark:text-white">Edit Skill</h1>

@{
    var isUsed = ViewBag.IsSkillUsed as bool? ?? false;
}

@if (isUsed)
{
    <div class="mb-6 px-4 py-3 rounded-lg bg-amber-50 border border-amber-200 text-amber-800 text-sm dark:bg-amber-900/20 dark:border-amber-800 dark:text-amber-300">
        This skill has been used in evaluations or assignments and cannot be edited. You can still deactivate it.
    </div>
}

@section ActionButtons {
    <a href="/Skill/Index"
       class="border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
        Back to Skills
    </a>
}

<form method="post" class="max-w-md space-y-4">
    <input type="hidden" name="skillIdEncrypted" value="@Model.IdEncrypted">

    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300">Skill Name <span class="text-red-500">*</span></label>
        <input type="text" name="name" value="@Model.Name" required
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus-visible:outline-none focus-visible:border-blue-500 focus-visible:ring-4 focus-visible:ring-[#96c0d9] dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100 @(isUsed ? "bg-gray-100 text-gray-500 cursor-not-allowed dark:bg-gray-850" : "")"
               @(isUsed ? "disabled" : "")>
    </div>
    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300">Description (optional)</label>
        <textarea name="description" rows="3" maxlength="150"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus-visible:outline-none focus-visible:border-blue-500 focus-visible:ring-4 focus-visible:ring-[#96c0d9] dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100 @(isUsed ? "bg-gray-100 text-gray-500 cursor-not-allowed dark:bg-gray-850" : "")"
                  @(isUsed ? "disabled" : "")>@Model.Description</textarea>
    </div>
    <div class="text-sm text-gray-400">
        Vector position: @Model.VectorPosition (immutable)
    </div>
    @if (!isUsed)
    {
        <div class="flex gap-3">
            <button type="submit"
                    class="bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep border border-transparent">
                Save Changes
            </button>
            <a href="/Skill/Index"
               class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-300 text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
                Cancel
            </a>
        </div>
    }
</form>
