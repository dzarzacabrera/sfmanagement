@model DashboardViewModel
@{
    ViewBag.ProjectIdEncrypted = Model.ProjectIdEncrypted;
}

<style>
    @@keyframes pulse-add-worker {
        0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(59,130,246,.4); }
        50% { transform: scale(1.08); box-shadow: 0 0 0 8px rgba(59,130,246,0); }
    }
    .pulse-add-worker {
        animation: pulse-add-worker 1.2s ease-in-out 3;
    }
</style>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-6 dark:bg-gray-800">
    <div class="flex items-center gap-3">
        <h1 class="text-2xl font-bold pt-2 text-brand dark:text-white">@Model.ProjectName</h1>
        @if (Model.IsFinalized)
        {
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-gray-100 text-gray-600 border border-gray-300 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600">
                Closed
            </span>
        }
    </div>
</div>

@section ActionButtons {
    @if (!Model.IsFinalized)
    {
        <div class="flex items-center gap-2">
            <button onclick="openCreateTaskPopup('@Model.ProjectIdEncrypted')"
                    class="bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep">
                + New Task
            </button>
            @if (Model.HasWorkersToAssignToProject)
            {
                <button id="btn-add-worker" onclick="openAddWorkerPopup('@Model.ProjectIdEncrypted')"
                        class="border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700 @(!Model.HasProjectWorkers ? "pulse-add-worker" : "")">
                    Add Worker
                </button>
            }
            <button id="btn-finalize" onclick="finalizeProject('@Model.ProjectIdEncrypted')"
                    class="border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700 transition-colors cursor-pointer whitespace-nowrap">
                Close Project
            </button>
        </div>
    }
}

@if (Model.IsFinalized)
{
    <div class="mb-6 p-4 rounded-lg bg-gray-50 border border-gray-200 text-gray-500 text-sm dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400">
        This project is closed. Tasks are no longer displayed.
    </div>
}

<script>
    window.__dashboardProjectIdEncrypted = '@Model.ProjectIdEncrypted';
    (function() {
        var btn = document.getElementById('btn-add-worker');
        if (btn && btn.classList.contains('pulse-add-worker')) {
            btn.addEventListener('animationend', function() {
                btn.classList.remove('pulse-add-worker');
            }, { once: true });
        }
    })();
</script>

@if ((bool)(ViewBag.NoProjects ?? false) || (bool)(ViewBag.NoActiveProjects ?? false))
{
    <div class="flex flex-col items-center justify-center text-center py-20">
        <svg class="w-16 h-16 text-gray-300 dark:text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <p class="text-lg font-medium text-gray-600 dark:text-gray-300 mb-1">Please create a project to get started</p>
        <a href="/Project/Create"
           class="mt-4 inline-flex items-center bg-brand text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-brand-deep transition-colors">
            + New Project
        </a>
    </div>
}
else
{
    <div id="kanban-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        @foreach (var (status, label, tasks) in new[] {
            ("Queued", "Queued", Model.QueuedTasks),
            ("InProgress", "In Progress", Model.InProgressTasks),
            ("InReview", "In Review", Model.BlockedTasks),
            ("Finish", "Finished", Model.FinishedTasks) })
        {
            <div class="bg-gray-100 rounded-xl p-3 kanban-column dark:bg-gray-800 dark:text-gray-100" data-status="@status">
                <h2 class="text-sm font-semibold uppercase tracking-wide text-brand mb-3 px-1 dark:text-brand">
                    @label <span class="ml-1 text-sm sm:text-pill bg-gray-200 px-1.5 py-0.5 rounded-full dark:bg-gray-700 dark:text-gray-300 task-count">@tasks.Count</span>
                </h2>
                <div class="space-y-4">
                    @foreach (var task in tasks)
                    {
                        <partial name="_TaskCard" model="task" />
                    }
                </div>
            </div>
        }
    </div>
}
