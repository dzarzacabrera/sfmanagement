@model DashboardViewModel

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">@Model.ProjectName</h1>
    <div class="flex gap-2">
        <a href="/Task/Create?projectId=@Model.ProjectId"
           class="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700">
            + New Task
        </a>
    </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    @foreach (var (status, label, color, tasks) in new[] {
        ("Queued", "Queued", "border-l-blue-500", Model.QueuedTasks),
        ("InProgress", "In Progress", "border-l-amber-500", Model.InProgressTasks),
        ("Blocked", "Blocked", "border-l-red-500", Model.BlockedTasks),
        ("Finish", "Finished", "border-l-green-500", Model.FinishedTasks) })
    {
        <div class="bg-gray-100 rounded-xl p-3 kanban-column" data-status="@status">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500 mb-3 px-1">
                @label <span class="ml-1 text-xs bg-gray-200 px-1.5 py-0.5 rounded-full">@tasks.Count</span>
            </h2>
            <div class="space-y-3">
                @foreach (var task in tasks)
                {
                    <div class="task-card bg-white rounded-lg border border-gray-200 border-l-4 @color p-3 cursor-move"
                         data-task-id="@task.Id" data-status="@task.Status">
                        <div class="flex items-start justify-between gap-2">
                            <h3 class="text-sm font-semibold">@task.Title</h3>
                            <span class="text-xs font-medium px-2 py-0.5 rounded-full
                                @(task.Criticality == Criticality.Critical ? "bg-red-100 text-red-700" :
                                  task.Criticality == Criticality.High ? "bg-orange-100 text-orange-700" :
                                  task.Criticality == Criticality.Medium ? "bg-blue-100 text-blue-700" :
                                  "bg-gray-100 text-gray-600")">
                                @task.Criticality
                            </span>
                        </div>
                        @if (!string.IsNullOrEmpty(task.Description))
                        {
                            <p class="text-xs text-gray-500 mt-1 line-clamp-2">@task.Description</p>
                        }
                        <div class="flex items-center justify-between mt-2">
                            <span class="text-xs text-gray-400">
                                @(task.AssignedWorkerName ?? "Unassigned")
                            </span>
                            <div class="flex gap-1">
                                @if (task.Status != ProjectTaskStatus.Finish)
                                {
                                    <button class="btn-assign text-xs px-2 py-1 rounded bg-gray-100 hover:bg-gray-200"
                                            data-task-id="@task.Id"
                                            onclick="openAssignModal(@task.Id, @Model.ProjectId)">
                                        Assign
                                    </button>
                                }
                                @if (task.Status == ProjectTaskStatus.Finish)
                                {
                                    <button class="btn-evaluate text-xs px-2 py-1 rounded bg-green-100 hover:bg-green-200 text-green-700"
                                            data-task-id="@task.Id"
                                            onclick="openEvaluationModal(@task.Id, @Model.ProjectId)">
                                        Evaluate
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
