@model DashboardViewModel
@{
    ViewBag.ProjectIdEncrypted = Model.ProjectIdEncrypted;
}

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-6 dark:bg-gray-800">
    <h1 class="text-2xl font-bold text-brand dark:text-white">@Model.ProjectName</h1>
    <div class="flex gap-2">
        <a href="/Task/Create?projectId=@Model.ProjectIdEncrypted"
           class="bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep">
            + New Task
        </a>
        <button onclick="openAddWorkerPopup('@Model.ProjectIdEncrypted')"
                class="border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
            Add Worker
        </button>
    </div>
</div>

<script>
    window.__dashboardProjectIdEncrypted = '@Model.ProjectIdEncrypted';
</script>

<div id="kanban-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    @foreach (var (status, label, tasks) in new[] {
        ("Queued", "Queued", Model.QueuedTasks),
        ("InProgress", "In Progress", Model.InProgressTasks),
        ("Finish", "Finished", Model.FinishedTasks),
        ("Blocked", "Blocked", Model.BlockedTasks) })
    {
        <div class="bg-gray-100 rounded-xl p-3 kanban-column dark:bg-gray-800 dark:text-gray-100" data-status="@status">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-brand mb-3 px-1 dark:text-brand">
                @label <span class="ml-1 text-sm sm:text-pill bg-gray-200 px-1.5 py-0.5 rounded-full dark:bg-gray-700 dark:text-gray-300 task-count">@tasks.Count</span>
            </h2>
            <div class="space-y-4">
                @foreach (var task in tasks)
                {
                    <partial name="_TaskCard" model="task" />
                }
            </div>
        </div>
    }
</div>
