@model DashboardViewModel

<div class="flex items-center justify-between mb-6 dark:bg-gray-800">
    <h1 class="text-2xl font-bold dark:text-white">@Model.ProjectName</h1>
    <div class="flex gap-2">
        <a href="/Task/Create?projectId=@Model.ProjectId"
           class="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700">
            + New Task
        </a>
    </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    @foreach (var (status, label, color, tasks) in new[] {
        ("Queued", "Queued", "border-l-blue-500", Model.QueuedTasks),
        ("InProgress", "In Progress", "border-l-amber-500", Model.InProgressTasks),
        ("Blocked", "Blocked", "border-l-red-500", Model.BlockedTasks),
        ("Finish", "Finished", "border-l-green-500", Model.FinishedTasks) })
    {
        <div class="bg-gray-100 rounded-xl p-3 kanban-column dark:bg-gray-800 dark:text-gray-100" data-status="@status">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500 mb-3 px-1 dark:text-gray-400">
                @label <span class="ml-1 text-xs bg-gray-200 px-1.5 py-0.5 rounded-full dark:bg-gray-700 dark:text-gray-300">@tasks.Count</span>
            </h2>
            <div class="space-y-3">
                @foreach (var task in tasks)
                {
                    <div class="task-card bg-white rounded-lg border border-gray-200 border-l-4 @color p-3 cursor-move dark:bg-gray-800 dark:border-gray-700 dark:text-gray-100"
                         data-task-id="@task.Id" data-status="@task.Status">
                        <div class="flex items-start justify-between gap-2">
                            <h3 class="text-sm font-semibold">@task.Title</h3>
                            <span class="text-xs font-medium px-2 py-0.5 rounded-full
                                @(task.Criticality == Criticality.Critical ? "bg-red-100 text-red-700" :
                                  task.Criticality == Criticality.High ? "bg-orange-100 text-orange-700" :
                                  task.Criticality == Criticality.Medium ? "bg-blue-100 text-blue-700" :
                                  "bg-gray-100 text-gray-600")">
                                @task.Criticality
                            </span>
                        </div>
                        @if (!string.IsNullOrEmpty(task.Description))
                        {
                            <p class="text-xs text-gray-500 mt-1 line-clamp-2 dark:text-gray-400">@task.Description</p>
                        }
                        @if (task.Skills?.Count > 0)
                        {
                            <div class="flex flex-wrap gap-1 mt-1">
                                @foreach (var skill in task.Skills)
                                {
                                    <span class="px-1.5 py-0.5 rounded text-[10px] font-medium bg-indigo-50 text-indigo-600 dark:bg-indigo-900 dark:text-indigo-300" data-tooltip="@skill.SkillName: @skill.RequiredLevel">@skill.SkillName</span>
                                }
                            </div>
                        }
                        <div class="flex items-start justify-between mt-2">
                            <div class="flex flex-wrap gap-1">
                                @if (task.AssignedWorkers?.Count > 0)
                                {
                                    foreach (var worker in task.AssignedWorkers)
                                    {
                                        <span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded bg-indigo-50 text-indigo-700 dark:bg-indigo-900 dark:text-indigo-300">
                                            @worker.WorkerName
                                            @if (task.Status != ProjectTaskStatus.Finish)
                                            {
                                                <button type="button" class="text-indigo-400 hover:text-red-500 font-bold leading-none"
                                                        data-tooltip="Remove @worker.WorkerName"
                                                        onclick="removeWorker(@task.Id, @worker.WorkerId, this)">
                                                    &times;
                                                </button>
                                            }
                                        </span>
                                    }
                                }
                                else
                                {
                                    <span class="text-xs text-gray-400 dark:text-gray-500">Unassigned</span>
                                }
                            </div>
                            <div class="flex gap-1 shrink-0">
                                @if (task.Status != ProjectTaskStatus.Finish)
                                {
                                    <button class="btn-assign text-xs px-2 py-1 rounded bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-gray-200"
                                            data-task-id="@task.Id"
                                            data-tooltip="Assign a worker to this task"
                                            onclick="openAssignModal(@task.Id, @Model.ProjectId)">
                                        Assign
                                    </button>
                                }
                                @if (task.Status == ProjectTaskStatus.Finish)
                                {
                                    <button class="btn-evaluate text-xs px-2 py-1 rounded bg-green-100 hover:bg-green-200 text-green-700 dark:bg-green-900 dark:hover:bg-green-800 dark:text-green-300"
                                            data-task-id="@task.Id"
                                            data-tooltip="Evaluate this completed task"
                                            onclick="openEvaluationModal(@task.Id, @Model.ProjectId)">
                                        Evaluate
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
