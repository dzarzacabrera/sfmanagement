@model AssignWorkerViewModel
@using SFManagement.Domain.Enums
@{
    var index = 0;

    string MatchColor(double pct)
    {
        if (pct < 20) return "#c82323";
        if (pct < 50) return "#e96e1d";
        if (pct < 80) return "#137712";
        if (pct <= 100) return "#198c9b";
        return "#2729bc";
    }

    string MatchBg(double pct)
    {
        if (pct < 20) return "rgba(200,35,35,0.1)";
        if (pct < 50) return "rgba(233,110,29,0.1)";
        if (pct < 80) return "rgba(19,119,18,0.1)";
        if (pct <= 100) return "rgba(25,140,155,0.1)";
        return "rgba(39,41,188,0.1)";
    }
}

<div class="flex items-center gap-2 mb-4">
    <span class="text-sm sm:text-xs font-bold px-2.5 py-0.5 rounded-full shrink-0
        @(Model.Criticality == Criticality.Critical ? "bg-red-50 text-red-700 border border-red-200" :
          Model.Criticality == Criticality.High ? "bg-orange-50 text-orange-700 border border-orange-200" :
          Model.Criticality == Criticality.Medium ? "bg-blue-50 text-blue-700 border border-blue-200" :
          "bg-gray-50 text-gray-600 border border-gray-200")">
        @Model.Criticality
    </span>
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white leading-tight truncate">@Model.TaskTitle</h2>
</div>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <p class="text-base sm:text-sm text-gray-500 mb-3 line-clamp-4 dark:text-gray-400 leading-relaxed">@Model.Description</p>
}

@if (Model.Skills?.Count > 0)
{
    <div class="flex flex-col gap-1.5 mb-3">
        <span class="text-sm sm:text-pill font-bold uppercase tracking-wider text-brand">Required Skills</span>
        <div class="flex flex-wrap gap-1.5">
            @foreach (var skill in Model.Skills)
            {
                <span class="inline-flex items-center text-sm sm:text-xs font-semibold rounded-md border border-brand-dark overflow-hidden">
                    <span class="px-2 py-0.5 bg-brand-light text-brand">@skill.SkillName</span>
                    <span class="px-1.5 py-0.5 bg-brand-dark text-white font-bold border-l border-brand-dark">@skill.RequiredLevel.ToString("0")</span>
                </span>
            }
        </div>
    </div>
}

<div class="border-t border-gray-200 dark:border-gray-700 my-3"></div>

<h3 class="text-sm font-semibold text-gray-800 dark:text-gray-200 mb-3">Cosine Similarity Ranking</h3>

<form id="assignForm" class="space-y-3 max-h-[55vh] sm:max-h-[50vh] overflow-y-auto">
    <input type="hidden" name="taskId" value="@Model.TaskId">
    @foreach (var worker in Model.Workers)
    {
        index++;
        var pct = worker.CompatibilityScore * 100;
        var displayPct = Math.Min(pct, 100);
        var isExpert = pct > 100;
        var matchColor = MatchColor(pct);
        var matchBg = MatchBg(pct);

        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 hover:shadow-md transition-shadow dark:bg-gray-800 dark:border-gray-700">
            <div class="flex items-start justify-between gap-3">
                <div class="flex items-center gap-3 min-w-0">
                    <span class="shrink-0 w-7 h-7 rounded-full text-white text-sm font-bold flex items-center justify-center @(index == 1 ? "bg-brand" : "")" @(index > 1 ? "style=background-color:rgba(33,102,143,0.25);color:#21668f" : "")>@index</span>
                    <div class="min-w-0">
                        <div class="text-sm font-semibold text-gray-900 dark:text-gray-100 truncate">@worker.Name</div>
                        <div class="text-sm text-gray-400 dark:text-gray-400 truncate">@worker.Role</div>
                    </div>
                </div>
                <div class="shrink-0 text-right">
                    <div class="text-lg font-bold" style="color:@matchColor">
                        @if (isExpert)
                        {
                            <span style="color:#e6a817;">&#9733;</span>
                        }
                        @displayPct.ToString("0")%
                    </div>
                    <div class="text-sm text-gray-400 uppercase tracking-wider" style="color:@matchColor">match</div>
                </div>
            </div>
            @if (Model.Skills?.Count > 0)
                {
                    <div class="flex items-start gap-2 mt-3">
                        <div class="flex flex-wrap gap-1.5 flex-1 min-w-0">
                            @foreach (var skill in Model.Skills)
                            {
                                var workerLevel = skill.SkillPosition < worker.SkillsVector.Length ? worker.SkillsVector[skill.SkillPosition] : 0;
                                var skillPct = skill.RequiredLevel > 0 ? workerLevel / skill.RequiredLevel * 100 : 0;
                                var textColor = MatchColor(skillPct);
                                var bgColor = MatchBg(skillPct);

                                <span class="inline-flex items-center text-sm sm:text-xs font-semibold rounded-md border overflow-hidden" style="border-color:@textColor;">
                                    <span class="px-2 py-0.5" style="background-color:@bgColor; color:@textColor;">
                                        @skill.SkillName
                                    </span>
                                    <span class="px-1.5 py-0.5 text-white font-bold border-l" style="background-color:@textColor; border-color:@textColor;">@workerLevel.ToString("0") / @skill.RequiredLevel.ToString("0")</span>
                                </span>
                            }
                        </div>
                        <button type="submit" class="w-1/4 shrink-0 text-sm font-medium px-3 py-1.5 rounded-lg bg-brand text-white hover:bg-brand-deep transition-colors"
                                onclick="this.form.querySelectorAll('input[name=\'workerId\']').forEach(function(i){i.remove()}); var inp=document.createElement('input'); inp.type='hidden'; inp.name='workerId'; inp.value=@worker.Id; this.form.appendChild(inp);">
                            Asignar
                        </button>
                    </div>
                }
                else
                {
                    <div class="mt-3 flex justify-end">
                        <button type="submit" class="w-1/4 text-sm font-medium px-3 py-1.5 rounded-lg bg-brand text-white hover:bg-brand-deep transition-colors"
                                onclick="this.form.querySelectorAll('input[name=\'workerId\']').forEach(function(i){i.remove()}); var inp=document.createElement('input'); inp.type='hidden'; inp.name='workerId'; inp.value=@worker.Id; this.form.appendChild(inp);">
                            Asignar
                        </button>
                    </div>
                }
        </div>
    }
</form>
