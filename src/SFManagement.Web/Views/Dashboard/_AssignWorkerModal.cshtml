@model AssignWorkerViewModel
@using SFManagement.Domain.Enums
@{
    var index = 0;

    string MatchColor(double pct)
    {
        if (pct < 20) return "#c82323";
        if (pct < 50) return "#e96e1d";
        if (pct < 80) return "#137712";
        if (pct <= 100) return "#2729bc";
        return "#7c3aed";
    }

    string MatchBg(double pct)
    {
        if (pct < 20) return "rgba(200,35,35,0.1)";
        if (pct < 50) return "rgba(233,110,29,0.1)";
        if (pct < 80) return "rgba(19,119,18,0.1)";
        if (pct <= 100) return "rgba(39,41,188,0.1)";
        return "rgba(243,232,255,0.1)";
    }
}

<div class="flex flex-col h-full">
    <div class="shrink-0 px-6 pt-6 pb-4">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white leading-tight truncate mb-1.5">@Model.TaskTitle</h2>
        <div class="flex items-center gap-2 text-sm">
            <span class="text-gray-700 font-medium" style="font-size:13px;">Priority:</span>
            <span class="inline-block font-bold px-2.5 py-0.5 rounded-full
                @(Model.Criticality == Criticality.Critical ? "bg-red-50 text-red-700 border border-red-300" :
                  Model.Criticality == Criticality.High ? "bg-orange-50 text-orange-700 border border-orange-300" :
                  Model.Criticality == Criticality.Medium ? "bg-blue-50 text-blue-700 border border-blue-300" :
                  "bg-gray-50 text-gray-600 border border-gray-300")" style="font-size:13px;">
                @Model.Criticality
            </span>
        </div>
    </div>
        <div class="flex flex-col flex-1 min-h-0 overflow-y-auto px-6 pb-6">
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-base sm:text-sm text-gray-500 mb-3 sm:line-clamp-4 line-clamp-3 dark:text-gray-400 leading-relaxed shrink-0">@Model.Description</p>
        }

        @if (Model.Skills?.Count > 0)
        {
            <div class="flex flex-col gap-1.5 mb-3 shrink-0">
                <span class="text-sm sm:text-pill font-bold uppercase tracking-wider text-brand">Required Skills</span>
                <div class="flex flex-wrap gap-1.5">
                    @foreach (var skill in Model.Skills)
                    {
                        <span class="inline-flex items-stretch text-sm sm:text-xs font-semibold rounded-md border border-brand-dark overflow-hidden">
                            <span class="px-2 py-0.5 bg-brand-light text-brand self-center">@skill.SkillName</span>
                            <span class="px-1.5 bg-brand-dark text-white font-bold border-l border-brand-dark flex items-center self-stretch">@skill.RequiredLevel.ToString("0.##")</span>
                        </span>
                    }
                </div>
            </div>
        }

        <div class="border-t border-gray-200 dark:border-gray-700 shrink-0"></div>

        @{
            void RenderRecCard(WorkerScoreDto worker, string label, string labelBg, string borderColor)
            {
                var pct = worker.CompatibilityScore * 100;
                var isExpert = worker.Exceeds;
                var matchColor = isExpert ? "#7C3AED" : MatchColor(pct);
                var matchBg = isExpert ? "#F3E8FF" : MatchBg(pct);
                var isAssigned = worker.IsAssigned;
                var selectedClass = isAssigned ? "selected" : "";
                var selectedStyle = isAssigned ? "border-color:#21668f;background-color:rgba(33,102,143,0.06)" : "";
                var rankCheckHidden = isAssigned ? "" : "hidden";

                <div class="assign-card worker-card bg-white rounded-xl border border-gray-200 shadow-sm p-4 cursor-pointer transition-all duration-150 hover:shadow-md dark:bg-gray-800 dark:border-gray-700 dark:text-gray-100 relative overflow-visible @selectedClass"
                     style="border-left-color:@borderColor;border-left-width:4px;@selectedStyle"
                     data-worker-id="@worker.IdEncrypted"
                     onclick="toggleWorkerSelect(this)">
                    <span class="absolute text-xs font-bold px-2 py-0.5 rounded" style="background-color:@labelBg;color:white;top:-8px;right:10px;border-radius:6px;z-index:1;">@label</span>
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex items-center gap-3 min-w-0">
                            <span class="rank-num shrink-0 w-7 h-7 rounded-full bg-brand/25 text-brand text-sm font-bold flex items-center justify-center @(isAssigned ? "hidden" : "")">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                            </span>
                            <span class="rank-check shrink-0 w-7 h-7 rounded-full bg-brand text-white flex items-center justify-center @rankCheckHidden">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                            </span>
                            <div class="min-w-0">
                                <div class="text-sm font-semibold text-gray-900 dark:text-gray-100 truncate">@worker.Name</div>
                                <div class="text-sm text-gray-400 dark:text-gray-400 truncate">@worker.Role</div>
                            </div>
                        </div>
                        <div class="shrink-0 text-right">
                            <div class="text-lg font-bold flex items-center justify-end gap-1" style="color:@matchColor">
                                @if (isExpert)
                                {
                                    <span style="color:#e6a817;">&#9733;</span>
                                    <span class="text-xs font-medium normal-case" style="color:#7C3AED;">EXCEEDS</span>
                                }
                                @pct.ToString("0")%
                            </div>
                            <div class="text-sm text-gray-400 uppercase tracking-wider" style="color:@matchColor">match</div>
                        </div>
                    </div>
                    @if (Model.Skills?.Count > 0)
                    {
                        <div class="flex items-start gap-2 mt-3">
                            <div class="flex flex-wrap gap-1.5 flex-1 min-w-0">
                                @foreach (var skill in Model.Skills)
                                {
                                    var workerLevel = skill.SkillPosition < worker.SkillsVector.Length ? worker.SkillsVector[skill.SkillPosition] : 0;
                                    var skillPct = skill.RequiredLevel > 0 ? workerLevel / skill.RequiredLevel * 100 : 0;
                                    var isExceeding = workerLevel > skill.RequiredLevel;
                                    var textColor = isExceeding ? "#7C3AED" : MatchColor(skillPct);
                                    var bgColor = isExceeding ? "#F3E8FF" : MatchBg(skillPct);

                                    <span class="inline-flex items-center text-sm sm:text-xs font-semibold rounded-md border overflow-hidden" style="border-color:@textColor;">
                                        <span class="px-2 py-0.5" style="background-color:@bgColor; color:@textColor;">
                                            @skill.SkillName
                                        </span>
                                        <span class="px-1.5 py-0.5 text-white font-bold border-l" style="background-color:@textColor; border-color:@textColor;">@workerLevel.ToString("0.##") / @skill.RequiredLevel.ToString("0.##")</span>
                                    </span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }

        <div id="assignWorkerList" class="space-y-3 mt-3 pb-4">

            @if (Model.MostEfficient != null || Model.GrowUp != null || Model.FastestToFinish != null)
            {
                <h3 class="text-sm font-semibold text-gray-800 dark:text-gray-200 mb-3">Recommended</h3>

                @if (Model.MostEfficient != null)
                {
                    RenderRecCard(Model.MostEfficient, "Most Efficient", "#22c55e", "#22c55e");
                }
                @if (Model.GrowUp != null)
                {
                    RenderRecCard(Model.GrowUp, "Grow Up", "#D97706", "#D97706");
                }
                @if (Model.FastestToFinish != null)
                {
                    RenderRecCard(Model.FastestToFinish, "Fastest to Finish", "#2563EB", "#2563EB");
                }

                <div class="border-t border-gray-200 dark:border-gray-700 my-3"></div>
            }

            <h3 class="text-sm font-semibold text-gray-800 dark:text-gray-200 mb-3">Cosine Similarity Ranking</h3>
            @foreach (var worker in Model.Workers)
            {
                index++;
                var pct = worker.CompatibilityScore * 100;
                var isExpert = worker.Exceeds;
                var matchColor = isExpert ? "#7C3AED" : MatchColor(pct);
                var matchBg = isExpert ? "#F3E8FF" : MatchBg(pct);

                var isAssigned = worker.IsAssigned;
                var selectedClass = isAssigned ? "selected" : "";
                var selectedStyle = isAssigned ? "border-color:#21668f;background-color:rgba(33,102,143,0.06)" : "";
                var rankNumHidden = isAssigned ? "hidden" : "";
                var rankCheckHidden = isAssigned ? "" : "hidden";

                <div class="assign-card worker-card bg-white rounded-xl border border-gray-200 shadow-sm p-4 cursor-pointer transition-all duration-150 hover:shadow-md dark:bg-gray-800 dark:border-gray-700 dark:text-gray-100 @selectedClass"
                     data-worker-id="@worker.IdEncrypted"
                     style="@selectedStyle"
                     onclick="toggleWorkerSelect(this)">
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex items-center gap-3 min-w-0">
                            <span class="rank-num shrink-0 w-7 h-7 rounded-full text-white text-sm font-bold flex items-center justify-center @(index == 1 ? "bg-brand" : "") @rankNumHidden" @(index > 1 ? "style=background-color:rgba(33,102,143,0.25);color:#21668f" : "")>@index</span>
                            <span class="rank-check shrink-0 w-7 h-7 rounded-full bg-brand text-white flex items-center justify-center @rankCheckHidden">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                            </span>
                            <div class="min-w-0">
                                <div class="text-sm font-semibold text-gray-900 dark:text-gray-100 truncate">@worker.Name</div>
                                <div class="text-sm text-gray-400 dark:text-gray-400 truncate">@worker.Role</div>
                            </div>
                        </div>
                        <div class="shrink-0 text-right">
                            <div class="text-lg font-bold flex items-center justify-end gap-1" style="color:@matchColor">
                                @if (isExpert)
                                {
                                    <span style="color:#e6a817;">&#9733;</span>
                                    <span class="text-xs font-medium normal-case" style="color:#7C3AED;">EXCEEDS</span>
                                }
                                @pct.ToString("0")%
                            </div>
                            <div class="text-sm text-gray-400 uppercase tracking-wider" style="color:@matchColor">match</div>
                        </div>
                    </div>
                    @if (Model.Skills?.Count > 0)
                    {
                        <div class="flex items-start gap-2 mt-3">
                            <div class="flex flex-wrap gap-1.5 flex-1 min-w-0">
                                @foreach (var skill in Model.Skills)
                                {
                                    var workerLevel = skill.SkillPosition < worker.SkillsVector.Length ? worker.SkillsVector[skill.SkillPosition] : 0;
                                    var skillPct = skill.RequiredLevel > 0 ? workerLevel / skill.RequiredLevel * 100 : 0;
                                    var isExceeding = workerLevel > skill.RequiredLevel;
                                    var textColor = isExceeding ? "#7C3AED" : MatchColor(skillPct);
                                    var bgColor = isExceeding ? "#F3E8FF" : MatchBg(skillPct);

                                    <span class="inline-flex items-center text-sm sm:text-xs font-semibold rounded-md border overflow-hidden" style="border-color:@textColor;">
                                        <span class="px-2 py-0.5" style="background-color:@bgColor; color:@textColor;">
                                            @skill.SkillName
                                        </span>
                                        <span class="px-1.5 py-0.5 text-white font-bold border-l" style="background-color:@textColor; border-color:@textColor;">@workerLevel.ToString("0.##") / @skill.RequiredLevel.ToString("0.##")</span>
                                    </span>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                    }
                </div>
            }
        </div>
    </div>

    <div class="flex justify-end gap-2 px-6 pb-4 pt-4 shrink-0 border-t border-gray-100 dark:border-gray-700">
        <button type="button" onclick="closeModal()"
                class="px-4 py-2 text-sm rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
            Cancel
        </button>
        <button id="assignBtn" type="button" disabled
                class="px-5 py-2 text-sm rounded-lg bg-brand text-white hover:bg-brand-deep font-medium disabled:opacity-40 disabled:cursor-not-allowed"
                onclick="submitAssignWorkers('@Model.TaskIdEncrypted')">
            Assign
        </button>
    </div>
</div>
