@model AssignWorkerViewModel

<h2 class="text-lg font-semibold mb-4 dark:text-white">Assign Worker</h2>
<p class="text-sm text-gray-500 mb-4 dark:text-gray-400">Task: <strong>@Model.TaskTitle</strong></p>

<form id="assignForm">
    <input type="hidden" name="taskId" value="@Model.TaskId">
    <div class="space-y-2 max-h-60 overflow-y-auto">
        @foreach (var worker in Model.Workers)
        {
            <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 cursor-pointer hover:bg-indigo-50 has-[:checked]:bg-indigo-50 has-[:checked]:border-indigo-300 dark:bg-gray-800 dark:border-gray-600 dark:hover:bg-gray-700">
                <input type="radio" name="workerId" value="@worker.Id" class="accent-indigo-600">
                <div>
                    <div class="text-sm font-medium dark:text-gray-200">@worker.Name</div>
                    <div class="text-xs text-gray-400 dark:text-gray-400">Compatibility: @worker.CompatibilityScore.ToString("0.00")</div>
                </div>
            </label>
        }
    </div>
    <div class="flex justify-end gap-2 mt-4">
        <button type="button" onclick="closeModal()"
                class="px-4 py-2 text-sm rounded-lg border border-gray-300 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
            Cancel
        </button>
        <button type="submit"
                class="px-4 py-2 text-sm rounded-lg bg-indigo-600 text-white hover:bg-indigo-700">
            Assign
        </button>
    </div>
</form>
