@model EvaluationViewModel

<h2 class="text-lg font-semibold mb-4 dark:text-white">Evaluate Task</h2>
<p class="text-sm text-gray-500 mb-4 dark:text-gray-400">
    Task: <strong>@Model.TaskTitle</strong>
</p>

<form id="evaluationForm">
    <input type="hidden" name="taskId" value="@Model.TaskId">
    @if (Model.AssignedWorkers?.Count > 1)
    {
        <div class="mb-4">
            <label class="block text-xs font-medium text-gray-600 mb-1 dark:text-gray-400">Worker</label>
            <select name="workerId" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100">
                @foreach (var w in Model.AssignedWorkers)
                {
                    <option value="@w.WorkerId">@w.WorkerName</option>
                }
            </select>
        </div>
    }
    else
    {
        <p class="text-sm text-gray-500 mb-4 dark:text-gray-400">Worker: <strong>@Model.WorkerName</strong></p>
        <input type="hidden" name="workerId" value="@Model.WorkerId">
    }
    <div class="space-y-3 max-h-60 overflow-y-auto">
        @for (int i = 0; i < Model.SkillPositions.Count; i++)
        {
            <div class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 dark:bg-gray-800 dark:border-gray-600">
                <span class="text-sm font-medium w-32 dark:text-gray-200">@Model.SkillPositions[i].SkillName</span>
                <input type="hidden" name="skillPositions" value="@Model.SkillPositions[i].Position">
                <select name="ratings" class="border border-gray-300 rounded px-2 py-1 text-sm dark:bg-gray-700 dark:border-gray-600 dark:text-gray-100">
                    <option value="Poor">Poor</option>
                    <option value="Average" selected>Average</option>
                    <option value="Good">Good</option>
                    <option value="Excellent">Excellent</option>
                </select>
            </div>
        }
    </div>
    <div class="flex justify-end gap-2 mt-4">
        <button type="button" onclick="closeModal()"
                class="px-4 py-2 text-sm rounded-lg border border-gray-300 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
            Cancel
        </button>
        <button type="submit"
                class="px-4 py-2 text-sm rounded-lg bg-green-600 text-white hover:bg-green-700">
            Submit Evaluation
        </button>
    </div>
</form>
