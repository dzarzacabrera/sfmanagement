@model SFManagement.Web.ViewModels.TaskCardDto
@using SFManagement.Domain.Enums
@{
    var color = Model.Status switch
    {
        ProjectTaskStatus.Queued => "border-l-blue-500",
        ProjectTaskStatus.InProgress => "border-l-amber-500",
        ProjectTaskStatus.Blocked => "border-l-red-500",
        ProjectTaskStatus.Finish => "border-l-green-500",
        _ => "border-l-gray-500"
    };
    var projectId = ViewBag.ProjectId is int pid ? pid : 1;
}
<div class="task-card bg-white rounded-xl border border-gray-200 border-l-4 @color p-4 shadow-sm hover:shadow-md transition-shadow duration-200 cursor-move dark:bg-gray-800 dark:border-gray-700"
     data-task-id="@Model.Id" data-status="@Model.Status" draggable="true">
    <div class="flex items-start justify-between gap-3">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 leading-tight">@Model.Title</h3>
        <span class="text-[11px] font-bold px-2.5 py-0.5 rounded-full shrink-0
            @(Model.Criticality == Criticality.Critical ? "bg-red-50 text-red-700 border border-red-200" :
              Model.Criticality == Criticality.High ? "bg-orange-50 text-orange-700 border border-orange-200" :
              Model.Criticality == Criticality.Medium ? "bg-blue-50 text-blue-700 border border-blue-200" :
              "bg-gray-50 text-gray-600 border border-gray-200")">
            @Model.Criticality
        </span>
    </div>
    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <p class="text-xs text-gray-500 mt-2 line-clamp-2 dark:text-gray-400 leading-relaxed">@Model.Description</p>
    }
    @if (Model.Skills?.Count > 0)
    {
        <div class="flex flex-col gap-1.5 mt-3">
            <span class="text-[10px] font-bold uppercase tracking-wider text-brand dark:text-brand">Skills</span>
            <div class="flex flex-wrap gap-1.5">
                @foreach (var skill in Model.Skills)
                {
                    <span class="inline-flex items-center text-[10px] font-semibold rounded-md border border-brand-dark overflow-hidden">
                        <span class="px-2 py-0.5 bg-brand-light text-brand dark:bg-brand-light/20 dark:text-blue-100">@skill.SkillName</span>
                        <span class="px-1.5 py-0.5 bg-brand-dark text-white font-bold border-l border-brand-dark">@skill.RequiredLevel.ToString("0")</span>
                    </span>
                }
            </div>
        </div>
    }
    <div class="my-3.5 border-t border-gray-100 dark:border-gray-700/60"></div>
    <div class="flex flex-col gap-2.5 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex flex-col gap-1.5">
            <span class="text-[10px] font-bold uppercase tracking-wider text-brand dark:text-brand">Assigned Team</span>
            <div class="flex flex-wrap gap-1.5 items-center">
                @if (Model.AssignedWorkers?.Count > 0)
                {
                    foreach (var worker in Model.AssignedWorkers)
                    {
                        <span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-md bg-blue-50 text-blue-700 font-medium border border-blue-200 dark:bg-blue-950/40 dark:text-blue-300 dark:border-blue-900/50">
                            @worker.WorkerName
                            @if (Model.Status != ProjectTaskStatus.Finish)
                            {
                                <button type="button" class="text-blue-400 hover:text-red-500 font-bold text-sm leading-none ml-0.5 transition-colors"
                                        data-tooltip="Remove @worker.WorkerName"
                                        onclick="removeWorker(@Model.Id, @worker.WorkerId, this)">
                                    &times;
                                </button>
                            }
                        </span>
                    }
                }
                else
                {
                    <span class="text-xs italic text-gray-400 dark:text-gray-500">Unassigned</span>
                }
            </div>
        </div>
        <div class="flex shrink-0 items-end justify-end">
            @if (Model.Status != ProjectTaskStatus.Finish)
            {
                <button class="btn-assign text-xs font-medium px-3 py-1.5 rounded-lg bg-brand text-white hover:bg-brand-deep transition-colors shadow-sm"
                        data-task-id="@Model.Id"
                        data-tooltip="Assign a worker to this task"
                        onclick="openAssignModal(@Model.Id, @projectId)">
                    Assign
                </button>
            }
            @if (Model.Status == ProjectTaskStatus.Finish)
            {
                <button class="btn-evaluate text-xs font-medium px-3 py-1.5 rounded-lg bg-brand text-white hover:bg-brand-deep transition-colors shadow-sm"
                        data-task-id="@Model.Id"
                        data-tooltip="Evaluate this completed task"
                        onclick="openEvaluationModal(@Model.Id, @projectId)">
                    Evaluate
                </button>
            }
        </div>
    </div>
</div>