@model IReadOnlyList<TaskDto>

@{
    var cardColors = new[]
    {
        "bg-blue-50/40 border border-blue-200",
        "bg-indigo-50/40 border border-indigo-200",
        "bg-emerald-50/40 border border-emerald-200",
        "bg-amber-50/40 border border-amber-200",
        "bg-fuchsia-50/40 border border-fuchsia-200",
        "bg-cyan-50/40 border border-cyan-200",
        "bg-rose-50/30 border border-rose-200",
        "bg-violet-50/40 border border-violet-200",
        "bg-lime-50/40 border border-lime-200",
        "bg-slate-50/50 border border-slate-300/60",
    };
    var rowColors = new[]
    {
        "bg-blue-50/40 border-l-4 border-l-blue-300",
        "bg-indigo-50/40 border-l-4 border-l-indigo-300",
        "bg-emerald-50/40 border-l-4 border-l-emerald-300",
        "bg-amber-50/40 border-l-4 border-l-amber-300",
        "bg-fuchsia-50/40 border-l-4 border-l-fuchsia-300",
        "bg-cyan-50/40 border-l-4 border-l-cyan-300",
        "bg-rose-50/40 border-l-4 border-l-rose-300",
        "bg-violet-50/40 border-l-4 border-l-violet-300",
        "bg-lime-50/40 border-l-4 border-l-lime-300",
        "bg-slate-50/40 border-l-4 border-l-slate-400",
    };
}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold dark:text-white">Tasks</h1>
    <div class="flex gap-2">
        <a href="/Task/Create?projectId=1"
           class="bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep dark:bg-brand dark:hover:bg-brand">
            + New Task
        </a>
    </div>
</div>

<div class="flex mb-6">
    <div class="flex items-stretch flex-1">
        <div class="relative flex-1 min-w-0">
            <input type="text" id="taskSearch"
                   class="w-full border border-gray-300 rounded-l-lg px-4 py-2.5 pr-8 text-sm focus-visible:outline-none focus-visible:border-blue-500 focus-visible:ring-4 focus-visible:ring-[#96c0d9] dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100 dark:placeholder-gray-400"
                   placeholder="Search tasks...">
            <button type="button" id="clearSearch"
                    class="hidden absolute right-2 top-1/2 -translate-y-1/2 p-0.5 rounded text-gray-400 hover:text-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 dark:hover:text-gray-200 transition-colors"
                    aria-label="Clear search">
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
        <select id="projectFilter"
                class="relative z-10 border border-gray-300 border-l-0 px-3 py-2 pr-3 text-sm rounded-r-lg xl:rounded-none focus-visible:outline-none focus-visible:border-blue-500 focus-visible:ring-4 focus-visible:ring-[#96c0d9] dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100">
            <option value="">All Projects</option>
            @foreach (var p in (IReadOnlyList<ProjectDto>)ViewBag.Projects)
            {
                <option value="@p.Id">@p.Name</option>
            }
        </select>
        <div class="hidden xl:flex border border-gray-300 border-l-0 rounded-r-lg dark:border-gray-600">
            <button type="button" id="viewList"
                    class="p-2.5 transition-colors text-gray-500 hover:bg-gray-50 dark:text-gray-400 dark:hover:bg-gray-700 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9] relative z-10"
                    title="List view">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
            <div class="w-px bg-gray-300 dark:bg-gray-600 shrink-0"></div>
            <button type="button" id="viewCards"
                    class="p-2.5 rounded-r-lg transition-colors bg-blue-50 text-brand focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9] relative z-10"
                    title="Card view">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                </svg>
            </button>
        </div>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="text-center py-12">
        <p class="text-gray-400 mb-4 dark:text-gray-500">No tasks yet.</p>
        <a href="/Task/Create?projectId=1"
           class="bg-brand text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-brand-deep">
            Create your first task
        </a>
    </div>
}
else
{
    <div id="taskCards" class="grid gap-4 sm:grid-cols-2 md:grid-cols-2 lg:grid-cols-3">
        @foreach (var task in Model)
        {
            var projectNameShort = task.ProjectName?.Length > 30
                ? task.ProjectName[..30] + "..."
                : (task.ProjectName ?? $"Project #{task.ProjectId}");
            var isFinishedAndEvaluated = task.Status == ProjectTaskStatus.Finish && task.AllWorkersEvaluated;
            var isArchived = task.Status == ProjectTaskStatus.Archived;

            <div class="task-card rounded-xl shadow-sm p-5 hover:shadow-md transition-shadow cursor-pointer dark:bg-gray-800 dark:border-gray-700 dark:text-gray-100 relative flex flex-col justify-between @cardColors[Math.Abs(task.ProjectId) % 10]"
                 data-task-id="@task.Id"
                 data-title="@task.Title.ToLower()"
                 data-project="@task.ProjectId"
                 onclick="location.href='/Task/Detail?taskId=@task.Id'">
                <div>
                    <div class="flex items-center justify-between mb-2">
                        <span class="px-2 py-0.5 rounded-full text-sm sm:text-xs font-medium
                            @(task.Status == ProjectTaskStatus.InProgress ? "bg-amber-100 text-amber-700" :
                              task.Status == ProjectTaskStatus.Blocked ? "bg-red-100 text-red-700" :
                              task.Status == ProjectTaskStatus.Finish ? "bg-green-100 text-green-700" :
                              task.Status == ProjectTaskStatus.Archived ? "bg-gray-100 text-gray-500" :
                              "bg-blue-100 text-blue-700")">
                            @task.Status
                        </span>
                        <span class="px-2 py-0.5 rounded-full text-sm sm:text-xs font-medium
                            @(task.Criticality == Criticality.Critical ? "bg-red-100 text-red-700" :
                              task.Criticality == Criticality.High ? "bg-orange-100 text-orange-700" :
                              task.Criticality == Criticality.Medium ? "bg-blue-100 text-blue-700" :
                              "bg-gray-100 text-gray-600")">
                            @task.Criticality
                        </span>
                    </div>
                    <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">@task.Title</h2>
                    <p class="text-base sm:text-sm text-gray-400 mt-1 dark:text-gray-400 truncate" title="@task.ProjectName">@projectNameShort</p>
                    @if (task.AssignedWorkers?.Count > 0)
                    {
                        <div class="mt-2 text-sm text-gray-500 dark:text-gray-400">
                            <span class="font-medium text-gray-700 dark:text-gray-300">Team:</span>
                            @string.Join(", ", task.AssignedWorkers.Select(w => w.WorkerName))
                        </div>
                    }
                </div>
                <div class="flex items-center justify-end pt-3 gap-2">
                    @if (isArchived)
                    {
                        <button onclick="event.stopPropagation(); changeStatus(@task.Id, 'Finish')"
                                class="bg-white border border-gray-300 text-gray-600 px-2 py-1.5 rounded-lg text-xs font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700 transition-colors whitespace-nowrap"
                                title="Restore to Finish">
                            Restore
                        </button>
                    }
                    else
                    {
                        @if (!isFinishedAndEvaluated)
                        {
                            <button onclick="event.stopPropagation(); openStatusSheet(@task.Id, '@task.Status', this)"
                                    class="flex items-center gap-1.5 px-2.5 py-1.5 border border-gray-300 rounded-lg text-xs font-semibold text-gray-700 bg-white hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:bg-gray-800 dark:hover:bg-gray-700 transition-colors whitespace-nowrap"
                                    title="Change status">
                                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                                </svg>
                                <span>Status</span>
                            </button>
                        }
                        @if (task.Status != ProjectTaskStatus.Finish)
                        {
                            <button onclick="event.stopPropagation(); openAssignModal(@task.Id, @task.ProjectId)"
                                    class="border border-transparent px-2 py-1.5 rounded-lg text-xs font-medium bg-brand text-white hover:bg-brand-deep transition-colors whitespace-nowrap"
                                    title="Assign worker">
                                Assign
                            </button>
                        }
                        @if (task.Status == ProjectTaskStatus.Finish && !task.AllWorkersEvaluated)
                        {
                            <button onclick="event.stopPropagation(); openEvaluationModal(@task.Id, @task.ProjectId)"
                                    class="border border-transparent px-2 py-1.5 rounded-lg text-xs font-medium bg-brand text-white hover:bg-brand-deep transition-colors whitespace-nowrap"
                                    title="Evaluate">
                                Evaluate
                            </button>
                        }
                        @if (isFinishedAndEvaluated)
                        {
                            <button onclick="event.stopPropagation(); archiveTask(@task.Id, @task.ProjectId, this)"
                                    class="border border-transparent px-2 py-1.5 rounded-lg text-xs font-medium bg-gray-600 text-white hover:bg-gray-700 shadow-sm transition-colors whitespace-nowrap"
                                    title="Archive task">
                                Archive
                            </button>
                        }
                    }
                </div>
            </div>
        }
    </div>

    <div id="taskList" class="hidden">
        <div class="rounded-xl border border-gray-200 shadow-sm bg-white overflow-hidden dark:bg-gray-800 dark:border-gray-700">
            <div class="grid grid-cols-12 items-center gap-4 py-2.5 px-4 border-b border-gray-100 dark:border-gray-700">
                <div class="col-span-3 text-xs font-semibold text-gray-400 tracking-wider uppercase">Title</div>
                <div class="col-span-2 text-xs font-semibold text-gray-400 tracking-wider uppercase">Project</div>
                <div class="col-span-1 text-xs font-semibold text-gray-400 tracking-wider uppercase">Status</div>
                <div class="col-span-1 text-xs font-semibold text-gray-400 tracking-wider uppercase">Criticality</div>
                <div class="col-span-2 text-xs font-semibold text-gray-400 tracking-wider uppercase">Assigned</div>
                <div class="col-span-3 text-xs font-semibold text-gray-400 tracking-wider uppercase text-right">Actions</div>
            </div>
            @foreach (var task in Model)
            {
                var projectNameShort = task.ProjectName?.Length > 30
                    ? task.ProjectName[..30] + "..."
                    : (task.ProjectName ?? $"Project #{task.ProjectId}");
                var isFinishedAndEvaluated = task.Status == ProjectTaskStatus.Finish && task.AllWorkersEvaluated;
                var isArchived = task.Status == ProjectTaskStatus.Archived;

                <div class="task-row grid grid-cols-12 items-center gap-4 border-b border-gray-100 last:border-b-0 py-3 px-4 hover:bg-gray-50 dark:border-gray-700 dark:hover:bg-gray-800 transition-colors @rowColors[Math.Abs(task.ProjectId) % 10]"
                     data-title="@task.Title.ToLower()"
                     data-project="@task.ProjectId">
                    <div class="col-span-3 font-semibold text-gray-900 dark:text-gray-100 text-sm truncate">
                        @task.Title
                    </div>
                    <div class="col-span-2 text-sm text-gray-500 dark:text-gray-400 truncate" title="@task.ProjectName">
                        @projectNameShort
                    </div>
                    <div class="col-span-1">
                        <span class="px-2 py-0.5 rounded-full text-sm sm:text-xs font-medium
                            @(task.Status == ProjectTaskStatus.InProgress ? "bg-amber-100 text-amber-700" :
                              task.Status == ProjectTaskStatus.Blocked ? "bg-red-100 text-red-700" :
                              task.Status == ProjectTaskStatus.Finish ? "bg-green-100 text-green-700" :
                              task.Status == ProjectTaskStatus.Archived ? "bg-gray-100 text-gray-500" :
                              "bg-blue-100 text-blue-700")">
                            @task.Status
                        </span>
                    </div>
                    <div class="col-span-1">
                        <span class="px-2 py-0.5 rounded-full text-sm sm:text-xs font-medium
                            @(task.Criticality == Criticality.Critical ? "bg-red-100 text-red-700" :
                              task.Criticality == Criticality.High ? "bg-orange-100 text-orange-700" :
                              task.Criticality == Criticality.Medium ? "bg-blue-100 text-blue-700" :
                              "bg-gray-100 text-gray-600")">
                            @task.Criticality
                        </span>
                    </div>
                    <div class="col-span-2 text-sm text-gray-500 dark:text-gray-300 truncate">
                        @if (task.AssignedWorkers?.Count > 0)
                        {
                            @string.Join(", ", task.AssignedWorkers.Select(w => w.WorkerName))
                        }
                        else
                        {
                            <text>&mdash;</text>
                        }
                    </div>
                    <div class="col-span-3 flex items-center justify-end">
                        <div class="flex items-center gap-1">
                            <a href="/Task/Detail?taskId=@task.Id"
                               class="p-2 rounded-lg text-blue-400 hover:text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9]"
                               title="View details">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                            </a>
                            @if (isArchived)
                            {
                                <button onclick="changeStatus(@task.Id, 'Finish')"
                                        class="p-2 rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9]"
                                        title="Restore to Finish">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                                    </svg>
                                </button>
                            }
                            else if (!isFinishedAndEvaluated)
                            {
                                <button onclick="openStatusSheet(@task.Id, '@task.Status', this)"
                                        class="p-2 rounded-lg text-amber-400 hover:text-amber-600 hover:bg-amber-50 dark:hover:bg-amber-900/20 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9]"
                                        title="Change status">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                                    </svg>
                                </button>
                                @if (task.Status != ProjectTaskStatus.Finish)
                                {
                                    <button onclick="openAssignModal(@task.Id, @task.ProjectId)"
                                            class="p-2 rounded-lg text-purple-400 hover:text-purple-600 hover:bg-purple-50 dark:hover:bg-purple-900/20 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9]"
                                            title="Assign worker">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                                        </svg>
                                    </button>
                                }
                                @if (task.Status == ProjectTaskStatus.Finish && !task.AllWorkersEvaluated)
                                {
                                    <button onclick="openEvaluationModal(@task.Id, @task.ProjectId)"
                                            class="p-2 rounded-lg text-purple-400 hover:text-purple-600 hover:bg-purple-50 dark:hover:bg-purple-900/20 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9]"
                                            title="Evaluate">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                        </svg>
                                    </button>
                                }
                            }
                            else
                            {
                                <button onclick="archiveTask(@task.Id, @task.ProjectId, this)"
                                        class="p-2 rounded-lg text-gray-500 hover:text-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9]"
                                        title="Archive">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
                                    </svg>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div id="emptyState" class="hidden text-center py-12">
        <p class="text-gray-400 dark:text-gray-500">No tasks match your search.</p>
    </div>
}

<script>
    function switchToCards() {
        document.getElementById('taskCards').classList.remove('hidden');
        document.getElementById('taskList').classList.add('hidden');
        document.getElementById('viewCards').className = 'p-2.5 transition-colors bg-blue-50 text-brand';
        document.getElementById('viewList').className = 'p-2.5 transition-colors text-gray-500 hover:bg-gray-50 dark:text-gray-400 dark:hover:bg-gray-700';
        localStorage.setItem('taskViewMode', 'cards');
    }

    function switchToList() {
        document.getElementById('taskCards').classList.add('hidden');
        document.getElementById('taskList').classList.remove('hidden');
        document.getElementById('viewList').className = 'p-2.5 transition-colors bg-blue-50 text-brand';
        document.getElementById('viewCards').className = 'p-2.5 transition-colors text-gray-500 hover:bg-gray-50 dark:text-gray-400 dark:hover:bg-gray-700';
        localStorage.setItem('taskViewMode', 'list');
    }

    function filterTasks() {
        var q = (document.getElementById('taskSearch').value || '').toLowerCase().trim();
        var project = document.getElementById('projectFilter').value;
        localStorage.setItem('taskSearchQuery', document.getElementById('taskSearch').value);
        localStorage.setItem('taskProjectFilter', project);
        var total = 0, hidden = 0;
        document.querySelectorAll('.task-card, .task-row').forEach(function (el) {
            total++;
            var match = true;
            if (q && !el.dataset.title.includes(q)) match = false;
            if (match && project && el.dataset.project !== project) match = false;
            el.style.display = match ? '' : 'none';
            if (!match) hidden++;
        });
        document.getElementById('emptyState').classList.toggle('hidden', hidden !== total);
        var clearBtn = document.getElementById('clearSearch');
        if (clearBtn) clearBtn.classList.toggle('hidden', !q);
    }

    var searchInput = document.getElementById('taskSearch');
    if (searchInput) {
        searchInput.addEventListener('input', filterTasks);
    }
    document.getElementById('clearSearch')?.addEventListener('click', function () {
        document.getElementById('taskSearch').value = '';
        localStorage.setItem('taskSearchQuery', '');
        filterTasks();
        document.getElementById('taskSearch').focus();
    });
    document.getElementById('projectFilter')?.addEventListener('change', filterTasks);

    document.getElementById('viewCards')?.addEventListener('click', function () {
        if (document.getElementById('taskCards').classList.contains('hidden')) {
            switchToCards();
        }
    });
    document.getElementById('viewList')?.addEventListener('click', function () {
        if (document.getElementById('taskList').classList.contains('hidden')) {
            switchToList();
        }
    });

    var mql = window.matchMedia('(max-width: 1199px)');
    mql.addEventListener('change', function (e) {
        if (e.matches) {
            if (document.getElementById('taskList') && !document.getElementById('taskList').classList.contains('hidden')) {
                switchToCards();
            }
        }
    });

    var savedView = localStorage.getItem('taskViewMode');
    var savedQuery = localStorage.getItem('taskSearchQuery');
    var savedProject = localStorage.getItem('taskProjectFilter');

    if (savedView === 'list' && !mql.matches) {
        switchToList();
    } else {
        if (mql.matches) switchToCards();
    }

    if (savedQuery && searchInput) {
        searchInput.value = savedQuery;
    }

    var projectFilter = document.getElementById('projectFilter');
    if (savedProject && projectFilter) {
        projectFilter.value = savedProject;
    }

    filterTasks();
</script>

<!-- safelist: bg-blue-50/40 border border-blue-200 bg-indigo-50/40 border border-indigo-200 bg-emerald-50/40 border border-emerald-200 bg-amber-50/40 border border-amber-200 bg-fuchsia-50/40 border border-fuchsia-200 bg-cyan-50/40 border border-cyan-200 bg-rose-50/30 border border-rose-200 bg-violet-50/40 border border-violet-200 bg-lime-50/40 border border-lime-200 bg-slate-50/50 border border-slate-300/60 bg-blue-50/40 border-l-4 border-l-blue-300 bg-indigo-50/40 border-l-4 border-l-indigo-300 bg-emerald-50/40 border-l-4 border-l-emerald-300 bg-amber-50/40 border-l-4 border-l-amber-300 bg-fuchsia-50/40 border-l-4 border-l-fuchsia-300 bg-cyan-50/40 border-l-4 border-l-cyan-300 bg-rose-50/40 border-l-4 border-l-rose-300 bg-violet-50/40 border-l-4 border-l-violet-300 bg-lime-50/40 border-l-4 border-l-lime-300 bg-slate-50/40 border-l-4 border-l-slate-400 -->
