@model CreateTaskViewModel

<h1 class="text-2xl font-bold mb-6">Create New Task</h1>

<form method="post" class="max-w-lg space-y-4">
    <input type="hidden" name="projectId" value="@Model.ProjectId">

    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
        <input type="text" name="title" required
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
    </div>
    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
        <textarea name="description" rows="4"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"></textarea>
    </div>
    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Criticality</label>
        <select name="criticality"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
            @foreach (var opt in Model.Criticalities)
            {
                <option value="@opt.Value">@opt.Label</option>
            }
        </select>
    </div>
    <fieldset>
        <legend class="text-sm font-medium text-gray-700 mb-2">Required Skills</legend>
        @await Html.PartialAsync("_SkillSelector", (IReadOnlyList<SkillDto>)ViewBag.AllSkills)
    </fieldset>
    <button type="submit"
            class="bg-indigo-600 text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700">
        Create Task
    </button>
</form>
