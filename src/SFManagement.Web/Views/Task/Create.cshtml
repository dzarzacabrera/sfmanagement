@model CreateTaskViewModel

<h1 class="text-2xl font-bold pt-2 mb-6 text-brand dark:text-white">Create New Task</h1>

<form method="post" class="max-w-lg space-y-4">
    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300">Project</label>
        <select name="projectIdEncrypted"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus-visible:outline-none focus-visible:border-blue-500 focus-visible:ring-4 focus-visible:ring-[#96c0d9] dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100">
            @foreach (var project in Model.Projects)
            {
                <option value="@project.IdEncrypted" selected="@(project.Id == Model.ProjectId ? true : null)">@project.Name</option>
            }
        </select>
    </div>

    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300">Title</label>
        <input type="text" name="title" required
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus-visible:outline-none focus-visible:border-blue-500 focus-visible:ring-4 focus-visible:ring-[#96c0d9] dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100">
    </div>
    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300">Description</label>
        <textarea name="description" rows="4"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus-visible:outline-none focus-visible:border-blue-500 focus-visible:ring-4 focus-visible:ring-[#96c0d9] dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100"></textarea>
    </div>
    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300">Priority</label>
        <select name="criticality"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus-visible:outline-none focus-visible:border-blue-500 focus-visible:ring-4 focus-visible:ring-[#96c0d9] dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100">
            @foreach (var opt in Model.Criticalities)
            {
                <option value="@opt.Value">@opt.Label</option>
            }
        </select>
    </div>
    <fieldset>
        <legend class="text-sm font-medium text-gray-700 mb-2 dark:text-gray-300">Required Skills</legend>
        @await Html.PartialAsync("_SkillSelector", (IReadOnlyList<SkillDto>)ViewBag.AllSkills)
    </fieldset>
    <div class="flex gap-3">
        <button type="submit"
                class="bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep dark:bg-brand dark:hover:bg-brand-deep border border-transparent">
            Create Task
        </button>
        <a href="/Task/Index"
           class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-300 text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
            Cancel
        </a>
    </div>
</form>

<script>
    document.querySelector('form').addEventListener('submit', function(e) {
        if (this.querySelectorAll('input[name="skillPositions"]').length === 0) {
            e.preventDefault();
            window.showToast('Please select at least one required skill.', 'error');
        }
    });
</script>
