@model CreateTaskViewModel

@section ActionButtons {
    <a href="/Task/Index" class="border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">Back to Tasks</a>
}

<h1 class="text-2xl font-bold pt-2 mb-6 text-brand dark:text-white">Create New Task</h1>

<form method="post" class="max-w-lg space-y-4">
    @await Html.PartialAsync("_CreateTaskForm", Model)

    <div class="flex gap-3">
        <button type="submit"
                class="bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep dark:bg-brand dark:hover:bg-brand-deep border border-transparent">
            Create Task
        </button>
        <a href="/Task/Index"
           class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-300 text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
            Cancel
        </a>
    </div>
</form>

<script>
    document.querySelector('form').addEventListener('submit', function(e) {
        if (!window.validateSkillSelection(this)) {
            e.preventDefault();
        }
    });
</script>
