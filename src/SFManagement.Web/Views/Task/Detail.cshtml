@model TaskDto

<h1 class="text-2xl font-bold pt-2 mb-6 text-brand dark:text-white">@Model.Title</h1>

@section ActionButtons {
    <div class="flex items-center gap-2">
        <a href="/Dashboard/Index?projectId=@Model.ProjectIdEncrypted"
           class="bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep whitespace-nowrap">
            Dashboard
        </a>
        <a href="/Task/Edit?taskId=@Model.IdEncrypted"
           class="inline-flex items-center gap-1.5 border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700 whitespace-nowrap">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
            Edit
        </a>
        <a href="/Task/Index"
           class="border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700 whitespace-nowrap">
            Back Tasks
        </a>
    </div>
}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-4">
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 dark:bg-gray-800 dark:border-gray-700">
            <h2 class="text-lg font-semibold mb-3 dark:text-white">Details</h2>
            <dl class="space-y-2 text-sm">
                <div class="flex gap-2">
                    <dt class="text-gray-500 dark:text-gray-400 w-24">Status</dt>
                    <dd>
                        <span class="px-2 py-0.5 rounded-full text-sm sm:text-xs font-medium
                            @(Model.Status == ProjectTaskStatus.InProgress ? "bg-amber-100 text-amber-700" :
                               Model.Status == ProjectTaskStatus.Test ? "bg-purple-100 text-purple-800" :
                               Model.Status == ProjectTaskStatus.Finish ? "bg-green-100 text-green-700" :
                              Model.Status == ProjectTaskStatus.Archived ? "bg-gray-100 text-gray-500" :
                              "bg-blue-100 text-blue-700")">
                            @Model.Status
                        </span>
                    </dd>
                </div>
                <div class="flex gap-2">
                    <dt class="text-gray-500 dark:text-gray-400 w-24">Priority</dt>
                    <dd>
                        <span class="px-2 py-0.5 rounded-full text-sm sm:text-xs font-medium
                            @(Model.Criticality == Criticality.Critical ? "bg-red-100 text-red-700" :
                              Model.Criticality == Criticality.High ? "bg-orange-100 text-orange-700" :
                              Model.Criticality == Criticality.Medium ? "bg-blue-100 text-blue-700" :
                              "bg-gray-100 text-gray-600")">
                            @Model.Criticality
                        </span>
                    </dd>
                </div>
                <div class="flex gap-2">
                    <dt class="text-gray-500 dark:text-gray-400 w-24">Project</dt>
                    <dd class="text-gray-700 dark:text-gray-300">@Model.ProjectName</dd>
                </div>
                <div class="flex gap-2">
                    <dt class="text-gray-500 dark:text-gray-400 w-24">Description</dt>
                    <dd class="text-gray-700 dark:text-gray-300">@(Model.Description ?? "—")</dd>
                </div>
            </dl>
        </div>

        @if (Model.Skills?.Count > 0)
        {
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 dark:bg-gray-800 dark:border-gray-700">
                <h2 class="text-lg font-semibold mb-3 dark:text-white">Required Skills</h2>
                <div class="flex flex-wrap gap-1.5">
                    @foreach (var skill in Model.Skills)
                    {
                        <span class="inline-flex items-stretch text-sm sm:text-xs font-semibold rounded-md border border-brand-dark overflow-hidden">
                            <span class="px-2 py-0.5 bg-brand-light text-brand self-center">@skill.SkillName</span>
                            <span class="px-1.5 bg-brand-dark text-white font-bold border-l border-brand-dark flex items-center self-stretch">@skill.RequiredLevel.ToString("0.##")</span>
                        </span>
                    }
                </div>
            </div>
        }
    </div>

    <div>
        @if (Model.AssignedWorkers?.Count > 0)
        {
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 dark:bg-gray-800 dark:border-gray-700">
                <h2 class="text-lg font-semibold mb-3 dark:text-white">Assigned Workers</h2>
                <ul class="space-y-2">
                    @foreach (var w in Model.AssignedWorkers)
                    {
                        <li class="text-sm">
                            <a href="/Worker/Detail?workerId=@w.WorkerIdEncrypted"
                               class="text-brand hover:text-brand-deep dark:text-brand dark:hover:text-brand">
                                @w.WorkerName
                            </a>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
</div>

