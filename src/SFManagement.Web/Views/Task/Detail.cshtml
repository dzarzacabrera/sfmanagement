@model TaskDto

@section ActionButtons {
    <div class="flex items-center gap-2">
        <a href="/Dashboard/Index?projectId=@Model.ProjectIdEncrypted"
           class="bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep whitespace-nowrap">
            Dashboard
        </a>
        <a href="/Task/Edit?taskId=@Model.IdEncrypted"
           class="inline-flex items-center gap-1.5 border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700 whitespace-nowrap">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
            Edit
        </a>
        <a href="/Task/Index"
           class="border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700 whitespace-nowrap">
            Back Tasks
        </a>
    </div>
}

<div class="mb-3 sm:mb-4">
    <h1 class="text-2xl font-bold pt-2 mb-3 text-brand dark:text-white">@Model.Title</h1>
    <div class="grid grid-cols-2 gap-4 mb-2.5">
        <div class="flex items-center gap-2">
            <dt class="text-gray-500 dark:text-gray-400 text-sm">Status</dt>
            <dd>
                <span class="px-2 py-0.5 rounded-full text-xs font-semibold
                    @(Model.Status == ProjectTaskStatus.InProgress ? "bg-amber-50 text-amber-700 border border-amber-300 dark:bg-amber-900/30 dark:text-amber-300 dark:border-amber-700" :
                      Model.Status == ProjectTaskStatus.Test ? "bg-purple-50 text-purple-700 border border-purple-300 dark:bg-purple-900/30 dark:text-purple-300 dark:border-purple-700" :
                      Model.Status == ProjectTaskStatus.Finish ? "bg-green-50 text-green-700 border border-green-300 dark:bg-green-900/30 dark:text-green-300 dark:border-green-700" :
                      Model.Status == ProjectTaskStatus.Archived ? "bg-gray-50 text-gray-600 border border-gray-300 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600" :
                      "bg-blue-50 text-blue-700 border border-blue-300 dark:bg-blue-900/30 dark:text-blue-300 dark:border-blue-700")">
                    @Model.Status
                </span>
            </dd>
        </div>
        <div class="flex items-center gap-2">
            <dt class="text-gray-500 dark:text-gray-400 text-sm">Priority</dt>
            <dd>
                <span class="px-2 py-0.5 rounded-full text-xs font-semibold
                    @(Model.Criticality == Criticality.Critical ? "bg-red-50 text-red-700 border border-red-300 dark:bg-red-900/30 dark:text-red-300 dark:border-red-700" :
                      Model.Criticality == Criticality.High ? "bg-orange-50 text-orange-700 border border-orange-300 dark:bg-orange-900/30 dark:text-orange-300 dark:border-orange-700" :
                      Model.Criticality == Criticality.Medium ? "bg-blue-50 text-blue-700 border border-blue-300 dark:bg-blue-900/30 dark:text-blue-300 dark:border-blue-700" :
                      "bg-gray-50 text-gray-600 border border-gray-300 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600")">
                    @Model.Criticality
                </span>
            </dd>
        </div>
    </div>
    <div class="flex items-center gap-2 text-sm">
        <dt class="text-gray-500 dark:text-gray-400">Project</dt>
        <dd class="text-gray-700 dark:text-gray-300">@Model.ProjectName</dd>
    </div>
    @if (Model.Description is not null)
    {
        <p class="text-gray-700 dark:text-gray-300 text-sm pt-2">@Model.Description</p>
    }
</div>

<div class="space-y-4 mt-4">
    @if (Model.Skills?.Count > 0)
    {
        <h2 class="text-lg font-semibold dark:text-white px-1">Required Skills</h2>
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 dark:bg-gray-800 dark:border-gray-700">
            <div class="flex flex-wrap gap-1.5">
                @foreach (var skill in Model.Skills)
                {
                    <span class="inline-flex items-stretch text-sm sm:text-xs font-semibold rounded-md border border-brand-dark overflow-hidden">
                        <span class="px-2 py-0.5 bg-brand-light text-brand self-center">@skill.SkillName</span>
                        <span class="px-1.5 bg-brand-dark text-white font-bold border-l border-brand-dark flex items-center self-stretch">@skill.RequiredLevel.ToString("0.##")</span>
                    </span>
                }
            </div>
        </div>
    }

    @if (Model.AssignedWorkers?.Count > 0)
    {
        <h2 class="text-lg font-semibold dark:text-white px-1">Assigned Workers</h2>
        <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
            @foreach (var w in Model.AssignedWorkers)
            {
                <div class="worker-card bg-white rounded-xl border border-gray-200 shadow-sm p-4 hover:shadow-md transition-shadow dark:bg-gray-800 dark:border-gray-700 dark:text-gray-100 cursor-pointer"
                     onclick="window.location='/Worker/Detail?workerId=@w.WorkerIdEncrypted'">
                    <div>
                        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100">@w.WorkerName</h3>
                        <p class="text-sm text-gray-400 dark:text-gray-400">@w.Role</p>
                    </div>
                </div>
            }
        </div>
    }
</div>
