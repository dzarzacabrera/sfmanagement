@model WorkerHistoryViewModel
@using System.Linq

<h1 class="text-2xl font-bold mb-6 text-brand dark:text-white">
    @Model.WorkerName
    <a href="/Worker/Edit?workerId=@Model.WorkerIdEncrypted"
       class="ml-3 text-sm font-medium text-brand hover:text-brand-deep dark:text-brand dark:hover:text-brand">
        Edit
    </a>
</h1>

@{
    var allSkills = (IReadOnlyList<SkillDto>?)ViewBag.AllSkills;
    var skillsVector = (float[]?)ViewBag.WorkerSkillsVector;
    var workerSkills = allSkills != null && skillsVector != null
        ? allSkills
            .Select(s => new { s.Name, Value = skillsVector.ElementAtOrDefault(s.VectorPosition) })
            .Where(s => s.Value > 0)
            .OrderByDescending(s => s.Value)
            .Cast<dynamic>()
            .ToList()
        : new List<dynamic>();
}

@if (workerSkills.Count > 0)
{
    <h2 class="text-lg font-semibold mb-3 dark:text-white">Skills</h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-6 gap-y-2 mb-6">
        @foreach (var skill in workerSkills)
        {
            <div class="skill-row flex items-center gap-2 text-sm">
                <span class="text-gray-700 dark:text-gray-300 flex-[36] min-[1800px]:flex-[34] min-w-0 truncate">@skill.Name</span>
                <div class="flex-[54] min-[1800px]:flex-[60] h-1.5 bg-gray-100 rounded-full overflow-hidden dark:bg-gray-700">
                    <div class="h-full bg-brand-dark rounded-full transition-all" style="width: @(skill.Value / 10.0 * 100)%"></div>
                </div>
                <span class="font-bold text-gray-900 dark:text-gray-100 flex-[10] min-[1800px]:flex-[6] text-right tabular-nums">@skill.Value.ToString("0.00")</span>
            </div>
        }
    </div>
}

@if (Model.AssignedTasks?.Count > 0)
{
    <h2 class="text-lg font-semibold mb-3 dark:text-white">Assigned Tasks</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-6">
        @foreach (var t in Model.AssignedTasks)
        {
            <a href="/Dashboard/Index?projectId=@t.ProjectIdEncrypted"
               class="block bg-white rounded-lg border border-gray-200 p-4 hover:shadow-md transition-shadow dark:bg-gray-800 dark:border-gray-700">
                <div class="text-sm text-gray-400 mb-1 dark:text-gray-400">@t.ProjectName</div>
                <div class="text-sm font-medium text-gray-900 dark:text-gray-100">@t.TaskTitle</div>
            </a>
        }
    </div>
}

<h2 class="text-lg font-semibold mb-3 dark:text-white">Evaluation History</h2>

@if (Model.Evaluations.Count == 0)
{
    <p class="text-gray-500 dark:text-gray-400">No evaluations recorded yet.</p>
}
else
{
    <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse dark:text-gray-100">
            <thead>
                <tr class="bg-gray-100 text-left dark:bg-gray-800">
                    <th class="px-4 py-2 font-medium text-gray-600 dark:text-gray-400">Date</th>
                    <th class="px-4 py-2 font-medium text-gray-600 dark:text-gray-400">Project</th>
                    <th class="px-4 py-2 font-medium text-gray-600 dark:text-gray-400">Task</th>
                    <th class="px-4 py-2 font-medium text-gray-600 dark:text-gray-400">Skill</th>
                    <th class="px-4 py-2 font-medium text-gray-600 dark:text-gray-400">Rating</th>
                    <th class="px-4 py-2 font-medium text-gray-600 dark:text-gray-400">Base Pts</th>
                    <th class="px-4 py-2 font-medium text-gray-600 dark:text-gray-400">Criticality</th>
                    <th class="px-4 py-2 font-medium text-gray-600 dark:text-gray-400">Impact</th>
                    <th class="px-4 py-2 font-medium text-gray-600 dark:text-gray-400">Previous</th>
                    <th class="px-4 py-2 font-medium text-gray-600 dark:text-gray-400">New</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var eval in Model.Evaluations)
                {
                    <tr class="border-t border-gray-200 hover:bg-gray-50 dark:border-gray-700">
                        <td class="px-4 py-2 text-gray-500 dark:text-gray-300">@eval.CreatedAt.ToString("g")</td>
                        <td class="px-4 py-2 dark:text-gray-300">@(eval.ProjectName ?? "—")</td>
                        <td class="px-4 py-2 dark:text-gray-300">@eval.TaskTitle</td>
                        <td class="px-4 py-2 dark:text-gray-300">@eval.SkillName</td>
                        <td class="px-4 py-2 font-mono dark:text-gray-300">@eval.Rating.ToString("0.00")</td>
                        <td class="px-4 py-2 font-mono dark:text-gray-300">@eval.BasePoints.ToString("+0.00;-0.00")</td>
                        <td class="px-4 py-2 dark:text-gray-300">@eval.Criticality</td>
                        <td class="px-4 py-2 font-mono dark:text-gray-300 @(eval.Impact >= 0 ? "text-green-600" : "text-red-600")">
                            @eval.Impact.ToString("+0.00;-0.00")
                        </td>
                        <td class="px-4 py-2 font-mono dark:text-gray-300">@eval.PreviousLevel.ToString("0.00")</td>
                        <td class="px-4 py-2 font-mono dark:text-gray-300">@eval.NewLevel.ToString("0.00")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
