@model WorkerHistoryViewModel
@using System.Linq
@{
    var projectDotColors = new[]
    {
        "#2563eb",
        "#4f46e5",
        "#059669",
        "#d97706",
        "#dc2626",
        "#0891b2",
        "#7c3aed",
        "#db2777",
        "#65a30d",
        "#ea580c"
    };
}

<h1 class="text-2xl font-bold pt-2 mb-6 text-brand dark:text-white">@Model.WorkerName</h1>

@section ActionButtons {
    <div class="flex items-center gap-2">
        <a href="/Worker/Edit?workerId=@Model.WorkerIdEncrypted"
           class="inline-flex items-center gap-1.5 bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep border border-transparent">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
            Edit
        </a>
        <a href="/Worker/Index"
           class="border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
            Back to Workers
        </a>
    </div>
}

@{
    var allSkills = (IReadOnlyList<SkillDto>?)ViewBag.AllSkills;
    var skillsVector = (float[]?)ViewBag.WorkerSkillsVector;
    var workerSkills = allSkills != null && skillsVector != null
        ? allSkills
            .Select(s => new { s.Name, Value = skillsVector.ElementAtOrDefault(s.VectorPosition) })
            .Where(s => s.Value > 0)
            .OrderByDescending(s => s.Value)
            .Cast<dynamic>()
            .ToList()
        : new List<dynamic>();
}

@if (workerSkills.Count > 0)
{
    <h2 class="text-lg font-semibold mb-3 dark:text-white">Skills</h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-6 gap-y-2 mb-6">
        @foreach (var skill in workerSkills)
        {
            <div class="skill-row flex items-center gap-2 text-sm">
                <span class="text-gray-700 dark:text-gray-300 flex-[36] min-[1800px]:flex-[34] min-w-0 truncate" data-tooltip="@skill.Name">@skill.Name</span>
                <div class="flex-[54] min-[1800px]:flex-[60] h-1.5 bg-gray-200 rounded-full overflow-hidden dark:bg-gray-700">
                    <div class="h-full bg-brand-dark rounded-full transition-all" style="width: @(((double)(skill.Value / 10.0 * 100)).ToString(System.Globalization.CultureInfo.InvariantCulture))%"></div>
                </div>
                <span class="font-bold text-gray-900 dark:text-gray-100 flex-[10] min-[1800px]:flex-[6] text-right tabular-nums">@skill.Value.ToString("0.00")</span>
            </div>
        }
    </div>
}

@if (Model.ActiveTasks?.Count > 0)
{
    <h2 class="text-lg font-semibold mb-3 dark:text-white">Active Tasks</h2>
    <div id="worker-tasks" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-4">
        @for (int i = 0; i < Model.ActiveTasks.Count; i++)
        {
            var t = Model.ActiveTasks[i];
             <a href="/Dashboard/Index?projectId=@t.ProjectIdEncrypted"
                class="block bg-white rounded-lg border border-gray-200 p-4 hover:shadow-md transition-shadow dark:bg-gray-800 dark:border-gray-700"
                data-pg-item>
                 <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 pr-12">@t.TaskTitle</h2>
                 <p class="text-sm text-gray-400 dark:text-gray-400 truncate mt-1 flex items-center gap-1.5" data-tooltip="@t.ProjectName">
                     <span class="project-dot shrink-0" style="background:@(projectDotColors[Math.Abs(t.ProjectId) % 10]);width:10px;height:10px;border-radius:50%;"></span>
                     <span class="truncate">@t.ProjectName</span>
                 </p>
                 <div class="flex items-center gap-2 flex-wrap mt-3">
                    <span class="text-gray-700 font-medium" style="font-size:13px;">Priority:</span>
                    <span class="px-1.5 py-0.5 rounded-full text-xs font-medium
                        @(t.Criticality == SFManagement.Domain.Enums.Criticality.Critical ? "bg-red-100 text-red-700" :
                          t.Criticality == SFManagement.Domain.Enums.Criticality.High ? "bg-orange-100 text-orange-700" :
                          t.Criticality == SFManagement.Domain.Enums.Criticality.Medium ? "bg-blue-100 text-blue-700" :
                          "bg-gray-100 text-gray-600")">@t.Criticality</span>
                    <span class="text-gray-700 font-medium" style="font-size:13px;">Status:</span>
                    <span class="px-1.5 py-0.5 rounded-full text-xs font-medium
                        @(t.Status == SFManagement.Domain.Enums.ProjectTaskStatus.InProgress ? "bg-amber-100 text-amber-700" :
                          t.Status == SFManagement.Domain.Enums.ProjectTaskStatus.Test ? "bg-purple-100 text-purple-700" :
                          t.Status == SFManagement.Domain.Enums.ProjectTaskStatus.Finish ? "bg-green-100 text-green-700" :
                          t.Status == SFManagement.Domain.Enums.ProjectTaskStatus.Archived ? "bg-gray-100 text-gray-500" :
                          "bg-blue-100 text-blue-700")">@t.Status</span>
                </div>
            </a>
        }
    </div>
    @await Html.PartialAsync("_Pagination", new PaginationViewModel(Model.ActiveTasks.Count, "tasks", PageSize: 10), new ViewDataDictionary(ViewData) { { "PaginationGrid", "worker-tasks" } })
}

<h2 class="text-lg font-semibold mb-3 dark:text-white">Evaluation History</h2>

@if (Model.Evaluations.Count == 0)
{
    <p class="text-gray-500 dark:text-gray-400">No evaluations recorded yet.</p>
}
else
{
    <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm dark:border-gray-700">
        <table class="w-full text-sm dark:text-gray-100">
            <thead>
                <tr class="bg-gray-50 text-left dark:bg-gray-800">
                    <th class="px-4 py-2.5 text-xs font-semibold text-gray-400 uppercase tracking-wider">Date</th>
                    <th class="px-4 py-2.5 text-xs font-semibold text-gray-400 uppercase tracking-wider">Project</th>
                    <th class="px-4 py-2.5 text-xs font-semibold text-gray-400 uppercase tracking-wider">Task</th>
                    <th class="px-4 py-2.5 text-xs font-semibold text-gray-400 uppercase tracking-wider">Skill</th>
                    <th class="px-4 py-2.5 text-xs font-semibold text-gray-400 uppercase tracking-wider">Rating</th>
                    <th class="px-4 py-2.5 text-xs font-semibold text-gray-400 uppercase tracking-wider">Base Pts</th>
                    <th class="px-4 py-2.5 text-xs font-semibold text-gray-400 uppercase tracking-wider">Priority</th>
                    <th class="px-4 py-2.5 text-xs font-semibold text-gray-400 uppercase tracking-wider">Impact</th>
                    <th class="px-4 py-2.5 text-xs font-semibold text-gray-400 uppercase tracking-wider">Previous</th>
                    <th class="px-4 py-2.5 text-xs font-semibold text-gray-400 uppercase tracking-wider">New</th>
                </tr>
            </thead>
            <tbody id="evaluationGrid">
                @foreach (var eval in Model.Evaluations)
                {
                    <tr class="border-t border-gray-100 hover:bg-gray-50 transition-colors dark:border-gray-700 dark:hover:bg-gray-800/50" data-pg-item>
                        <td class="px-4 py-2.5 text-gray-500 dark:text-gray-300 whitespace-nowrap">@eval.CreatedAt.ToString("g")</td>
                        <td class="px-4 py-2.5 dark:text-gray-300">@(eval.ProjectName ?? "—")</td>
                        <td class="px-4 py-2.5 dark:text-gray-300">@eval.TaskTitle</td>
                        <td class="px-4 py-2.5 dark:text-gray-300">@eval.SkillName</td>
                        <td class="px-4 py-2.5 font-mono dark:text-gray-300 tabular-nums">@eval.Rating.ToString("0.00")</td>
                        <td class="px-4 py-2.5 font-mono dark:text-gray-300 tabular-nums">@eval.BasePoints.ToString("+0.00;-0.00")</td>
                        <td class="px-4 py-2.5 dark:text-gray-300">@eval.Criticality</td>
                        <td class="px-4 py-2.5 font-mono tabular-nums @(eval.Impact > 0 ? "text-green-600" : eval.Impact < 0 ? "text-red-600" : "text-gray-400")">
                            @if (eval.Impact > 0)
                            {
                                <span>▲</span>
                            }
                            else if (eval.Impact < 0)
                            {
                                <span>▼</span>
                            }
                            else
                            {
                                <span style="font-size:0.6rem">◀▶</span>
                            }
                            @eval.Impact.ToString("+0.00;-0.00")
                        </td>
                        <td class="px-4 py-2.5 font-mono dark:text-gray-300 tabular-nums">@eval.PreviousLevel.ToString("0.00")</td>
                        <td class="px-4 py-2.5 font-mono dark:text-gray-300 tabular-nums">@eval.NewLevel.ToString("0.00")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @await Html.PartialAsync("_Pagination", new PaginationViewModel(Model.Evaluations.Count, "evaluations"), new ViewDataDictionary(ViewData) { { "PaginationGrid", "evaluationGrid" } })
}
