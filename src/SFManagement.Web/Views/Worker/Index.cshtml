@model IReadOnlyList<WorkerDto>
@using System.Linq
@using System.Text.Json
@{
    var skills = (IReadOnlyList<SkillDto>)ViewBag.AllSkills;
    var skillsJson = JsonSerializer.Serialize(skills.Select(s => new { s.Name, s.VectorPosition }));
}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold dark:text-white">Workers</h1>
    <a href="/Worker/Create"
       class="bg-brand text-white px-3 py-1.5 rounded-lg text-xs font-medium hover:bg-brand-deep dark:bg-brand dark:hover:bg-brand-deep">
        + Worker
    </a>
</div>

<input type="text" id="workerSearch"
       class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm mb-6 focus:ring-2 focus:ring-brand focus:border-brand dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100 dark:placeholder-gray-400"
       placeholder="Search workers by name...">

@if (Model.Count == 0)
{
    <div class="text-center py-12">
        <p class="text-gray-400 dark:text-gray-500 mb-4">No workers yet.</p>
        <a href="/Worker/Create"
           class="bg-brand text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-brand-deep">
            Create your first worker
        </a>
    </div>
}
else
{
    <div id="workerGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        @foreach (var worker in Model)
        {
            var workerSkills = skills
                .Select(s => new { s.Name, Value = worker.SkillsVector.ElementAtOrDefault(s.VectorPosition) })
                .Where(s => s.Value > 0)
                .OrderByDescending(s => s.Value)
                .ToList();

            var initials = string.Concat(
                (worker.Name.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                    .Take(2).Select(w => w[0]))).ToUpper();

            <div class="worker-card bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md transition-shadow dark:bg-gray-800 dark:border-gray-700 dark:text-gray-100"
                 data-name="@worker.Name.ToLower()">
                <div class="flex items-start gap-3 mb-4">
                    <div class="w-10 h-10 rounded-full bg-brand-light/40 text-brand flex items-center justify-center text-sm font-bold shrink-0 dark:bg-brand-deep dark:text-brand">
                        @initials
                    </div>
                    <div class="min-w-0 flex-1">
                        <div class="font-semibold text-gray-900 truncate dark:text-gray-100">@worker.Name</div>
                        <div class="text-xs text-gray-500 truncate dark:text-gray-400">@worker.Role</div>
                    </div>
                    <div class="text-xs text-gray-400 whitespace-nowrap shrink-0 dark:text-gray-500">
                        @worker.ActiveTaskCount tasks | @worker.EvaluationCount evaluations
                    </div>
                </div>

                <div class="space-y-2">
                    @for (int i = 0; i < workerSkills.Count; i++)
                    {
                        var skill = workerSkills[i];
                        <div class="skill-row flex items-center gap-2 text-xs @(i >= 4 ? "hidden extra-skill" : "")">
                            <span class="text-gray-700 dark:text-gray-300 flex-[36] min-[1800px]:flex-[34] min-w-0 truncate">@skill.Name</span>
                            <div class="flex-[54] min-[1800px]:flex-[60] h-1.5 bg-gray-100 rounded-full overflow-hidden dark:bg-gray-700">
                                <div class="h-full bg-brand-dark rounded-full transition-all" style="width: @(skill.Value / 10.0 * 100)%"></div>
                            </div>
                            <span class="font-bold text-gray-900 dark:text-gray-100 flex-[10] min-[1800px]:flex-[6] text-right tabular-nums">@skill.Value.ToString("0.00")</span>
                        </div>
                    }
                </div>

                @if (workerSkills.Count > 4)
                {
                    <button type="button"
                            class="toggle-skills mt-3 text-xs text-brand hover:text-brand-deep font-medium w-full text-left"
                            data-expanded="false">
                        + @(workerSkills.Count - 4) more skills
                    </button>
                }

                <div class="mt-4 pt-3 border-t border-gray-100 flex gap-3 dark:border-gray-700">
                    <a href="/Worker/Detail?workerId=@worker.Id"
                       class="text-xs text-brand hover:text-brand-deep font-medium dark:text-brand dark:hover:text-brand">Detail</a>
                    <a href="/Worker/Edit?workerId=@worker.Id"
                       class="text-xs text-brand hover:text-brand-deep font-medium dark:text-brand dark:hover:text-brand">Edit</a>
                </div>
            </div>
        }
    </div>

    <div id="emptyState" class="hidden text-center py-12">
        <p class="text-gray-400">No workers match your search.</p>
    </div>
}

<script>
    document.getElementById('workerSearch')?.addEventListener('input', function () {
        var q = this.value.toLowerCase().trim();
        var cards = document.querySelectorAll('.worker-card');
        var visibleCount = 0;
        cards.forEach(function (c) {
            var match = !q || c.dataset.name.includes(q);
            c.style.display = match ? '' : 'none';
            if (match) visibleCount++;
        });
        var es = document.getElementById('emptyState');
        if (es) es.classList.toggle('hidden', visibleCount > 0);
    });

    document.querySelectorAll('.toggle-skills').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var expanded = this.dataset.expanded === 'true';
            var card = this.closest('.worker-card');
            var extras = card.querySelectorAll('.extra-skill');
            if (expanded) {
                extras.forEach(function (e) { e.classList.add('hidden'); });
                var count = extras.length;
                this.textContent = '+ ' + count + ' more skills';
                this.dataset.expanded = 'false';
            } else {
                extras.forEach(function (e, i) {
                    setTimeout(function () { e.classList.remove('hidden'); }, i * 50);
                });
                this.textContent = 'Show less';
                this.dataset.expanded = 'true';
            }
        });
    });
</script>
