@model IReadOnlyList<WorkerDto>
@using System.Linq
@using System.Text.Json
@{
    var skills = (IReadOnlyList<SkillDto>)ViewBag.AllSkills;
    var skillsJson = JsonSerializer.Serialize(skills.Select(s => new { s.Name, s.VectorPosition }));
}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">Workers</h1>
    <a href="/Worker/Create"
       class="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700">
        + Add Worker
    </a>
</div>

<input type="text" id="workerSearch"
       class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm mb-6 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
       placeholder="Search workers by name...">

@if (Model.Count == 0)
{
    <div class="text-center py-12">
        <p class="text-gray-400 mb-4">No workers yet.</p>
        <a href="/Worker/Create"
           class="bg-indigo-600 text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700">
            Create your first worker
        </a>
    </div>
}
else
{
    <div id="workerGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        @foreach (var worker in Model)
        {
            var workerSkills = skills
                .Select(s => new { s.Name, Value = worker.SkillsVector.ElementAtOrDefault(s.VectorPosition) })
                .Where(s => s.Value > 0)
                .OrderByDescending(s => s.Value)
                .ToList();

            var initials = string.Concat(
                (worker.Name.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                    .Take(2).Select(w => w[0]))).ToUpper();

            <div class="worker-card bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md transition-shadow"
                 data-name="@worker.Name.ToLower()">
                <div class="flex items-start gap-3 mb-4">
                    <div class="w-10 h-10 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-sm font-bold shrink-0">
                        @initials
                    </div>
                    <div class="min-w-0 flex-1">
                        <div class="font-semibold text-gray-900 truncate">@worker.Name</div>
                        <div class="text-xs text-gray-500 truncate">@worker.Role</div>
                    </div>
                    <div class="text-xs text-gray-400 whitespace-nowrap shrink-0">@worker.EvaluationCount evaluations</div>
                </div>

                <div class="space-y-2">
                    @for (int i = 0; i < workerSkills.Count; i++)
                    {
                        var skill = workerSkills[i];
                        <div class="skill-row @(i >= 4 ? "hidden extra-skill" : "")">
                            <div class="flex items-center justify-between text-xs mb-0.5">
                                <span class="text-gray-700 truncate">@skill.Name</span>
                                <span class="font-mono text-gray-500 ml-2">@skill.Value.ToString("0.0")</span>
                            </div>
                            <div class="w-full h-1.5 bg-gray-100 rounded-full overflow-hidden">
                                <div class="h-full bg-indigo-500 rounded-full transition-all" style="width: @(skill.Value / 10.0 * 100)%"></div>
                            </div>
                        </div>
                    }
                </div>

                @if (workerSkills.Count > 4)
                {
                    <button type="button"
                            class="toggle-skills mt-3 text-xs text-indigo-600 hover:text-indigo-800 font-medium w-full text-left"
                            data-expanded="false">
                        + @(workerSkills.Count - 4) more skills
                    </button>
                }

                <div class="mt-4 pt-3 border-t border-gray-100 flex gap-3">
                    <a href="/Worker/Detail?workerId=@worker.Id"
                       class="text-xs text-indigo-600 hover:text-indigo-800 font-medium">Detail</a>
                    <a href="/Worker/Edit?workerId=@worker.Id"
                       class="text-xs text-indigo-600 hover:text-indigo-800 font-medium">Edit</a>
                </div>
            </div>
        }
    </div>

    <div id="emptyState" class="hidden text-center py-12">
        <p class="text-gray-400">No workers match your search.</p>
    </div>
}

<script>
    document.getElementById('workerSearch')?.addEventListener('input', function () {
        var q = this.value.toLowerCase().trim();
        var cards = document.querySelectorAll('.worker-card');
        var visibleCount = 0;
        cards.forEach(function (c) {
            var match = !q || c.dataset.name.includes(q);
            c.style.display = match ? '' : 'none';
            if (match) visibleCount++;
        });
        var es = document.getElementById('emptyState');
        if (es) es.classList.toggle('hidden', visibleCount > 0);
    });

    document.querySelectorAll('.toggle-skills').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var expanded = this.dataset.expanded === 'true';
            var card = this.closest('.worker-card');
            var extras = card.querySelectorAll('.extra-skill');
            if (expanded) {
                extras.forEach(function (e) { e.style.display = 'none'; });
                var count = extras.length;
                this.textContent = '+ ' + count + ' more skills';
                this.dataset.expanded = 'false';
            } else {
                extras.forEach(function (e, i) {
                    setTimeout(function () { e.style.display = 'flex'; }, i * 50);
                });
                this.textContent = 'Show less';
                this.dataset.expanded = 'true';
            }
        });
    });
</script>
