<h1 class="text-2xl font-bold mb-6 dark:text-white">Add Worker</h1>

<form method="post" class="max-w-md space-y-4">
    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300">Worker Name</label>
        <input type="text" name="name" required
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-brand focus:border-brand dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100">
    </div>
    <button type="submit"
            class="bg-brand text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-brand-deep">
        Create Worker
    </button>
</form>
