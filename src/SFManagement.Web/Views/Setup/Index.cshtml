@{
    Layout = "_Layout";
}

<div class="mb-6">
    <h1 class="text-2xl font-bold pt-2 mb-6 text-brand dark:text-white">Setup</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
        Demo tools to prepare the application environment.
    </p>
</div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <!-- Clear Database -->
        <div class="rounded-xl border border-red-200 bg-white dark:bg-[#262636] dark:border-red-900/40 p-5 flex flex-col">
            <div class="flex items-center gap-3 mb-3">
                <span class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-red-50 text-red-600 dark:bg-red-900/30 dark:text-red-300">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                </span>
                <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-100">Clear Database</h2>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 flex-1">
                Empties all application tables completely, leaving the database clean with no records.
            </p>
            <button id="btn-clear"
                class="mt-5 self-end inline-flex items-center justify-center gap-2 rounded-lg bg-white hover:bg-red-50 text-red-600 border border-red-600 font-medium px-4 py-2.5 transition disabled:opacity-60 dark:bg-gray-800 dark:text-red-400 dark:border-red-500 dark:hover:bg-red-900/20"
                onclick="openClearModal()">
                <span class="btn-label">Clear All Database</span>
                <span class="btn-spinner hidden w-4 h-4 border-2 border-red-200 border-t-red-600 rounded-full animate-spin dark:border-red-800 dark:border-t-red-400"></span>
            </button>
        </div>

        <!-- Import Seed Data -->
        <div class="rounded-xl border border-green-200 bg-white dark:bg-[#262636] dark:border-green-900/40 p-5 flex flex-col">
            <div class="flex items-center gap-3 mb-3">
                <span class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-green-50 text-green-600 dark:bg-green-900/30 dark:text-green-300">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                </span>
                <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-100">Import Seed Data</h2>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 flex-1">
                Loads a predefined set of fake data to test the application with sample projects, workers and tasks.
            </p>
            <button id="btn-import"
                class="mt-5 self-end inline-flex items-center justify-center gap-2 rounded-lg bg-white hover:bg-green-50 text-green-600 border border-green-600 font-medium px-4 py-2.5 transition disabled:opacity-60 dark:bg-gray-800 dark:text-green-400 dark:border-green-500 dark:hover:bg-green-900/20"
                onclick="openImportModal()">
                <span class="btn-label">Import Sample Data</span>
                <span class="btn-spinner hidden w-4 h-4 border-2 border-green-200 border-t-green-600 rounded-full animate-spin dark:border-green-800 dark:border-t-green-400"></span>
            </button>
        </div>
</div>

<script>
    function setLoading(btn, loading) {
        var label = btn.querySelector('.btn-label');
        var spinner = btn.querySelector('.btn-spinner');
        btn.disabled = loading;
        if (loading) { spinner.classList.remove('hidden'); }
        else { spinner.classList.add('hidden'); }
    }

    function setupMobileSheet() {
        var content = document.getElementById('modal-content');
        if (content) {
            content.style.height = 'auto';
            content.style.maxHeight = 'none';
        }
        var panel = document.getElementById('modal-panel');
        if (panel) panel.style.maxHeight = 'none';
    }

    function openClearModal() {
        var html = ''
            + '<h3 class="text-lg font-semibold text-gray-800 dark:text-gray-100 mb-2">Confirm Deletion</h3>'
            + '<p class="text-sm text-gray-600 dark:text-gray-300 mb-5">Are you sure you want to delete all application data? This action cannot be undone.</p>'
            + '<div class="flex justify-end gap-3">'
            +   '<button class="px-4 py-2 rounded-lg text-sm font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:text-gray-200 dark:hover:bg-gray-600" onclick="closeModal()">Cancel</button>'
            +   '<button id="modal-confirm-clear" class="px-4 py-2 rounded-lg text-sm font-medium text-white bg-red-600 hover:bg-red-700" onclick="confirmClear()">Delete everything</button>'
            + '</div>';
        openModal(html, true);
        setupMobileSheet();
    }

    function openImportModal() {
        var html = ''
            + '<h3 class="text-lg font-semibold text-gray-800 dark:text-gray-100 mb-2">Confirm Import</h3>'
            + '<p class="text-sm text-gray-600 dark:text-gray-300 mb-5">Do you want to import the initial test data? If data already exists, the base records will be added.</p>'
            + '<div class="flex justify-end gap-3">'
            +   '<button class="px-4 py-2 rounded-lg text-sm font-medium text-gray-600 bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:text-gray-200 dark:hover:bg-gray-600" onclick="closeModal()">Cancel</button>'
            +   '<button id="modal-confirm-import" class="px-4 py-2 rounded-lg text-sm font-medium text-white bg-green-600 hover:bg-green-700" onclick="confirmImport()">Import data</button>'
            + '</div>';
        openModal(html, true);
        setupMobileSheet();
    }

    function confirmClear() {
        closeModal();
        var btn = document.getElementById('btn-clear');
        setLoading(btn, true);
        fetch('/Setup/ClearDatabase', { method: 'POST' })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                setLoading(btn, false);
                if (data.success) {
                    localStorage.removeItem('lastProjectId');
                    showToast('Database cleared successfully.', 'success', null, btn);
                } else {
                    showToast(data.message || 'Could not clear the database.', 'error', null, btn);
                }
            })
            .catch(function () {
                setLoading(btn, false);
                showToast('Connection error with the server.', 'error', null, btn);
            });
    }

    function confirmImport() {
        closeModal();
        var btn = document.getElementById('btn-import');
        setLoading(btn, true);
        fetch('/Setup/ImportSeedData', { method: 'POST' })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                setLoading(btn, false);
                if (data.success) {
                    localStorage.removeItem('lastProjectId');
                    showToast('Sample data imported successfully.', 'success', null, btn);
                } else {
                    showToast(data.message || 'Could not import the data.', 'error', null, btn);
                }
            })
            .catch(function () {
                setLoading(btn, false);
                showToast('Connection error with the server.', 'error', null, btn);
            });
    }
</script>
