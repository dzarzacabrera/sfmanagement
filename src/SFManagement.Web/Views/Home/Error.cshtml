@{
    ViewBag.PageTitle = "Error";
}

<div class="flex min-h-[60vh] items-center justify-center px-4">
    <div class="text-center">
        <h1 class="text-6xl font-bold text-red-500">Error</h1>
        <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
            Ha ocurrido un error inesperado. Por favor, intenta de nuevo o contacta al administrador.
        </p>
        <a href="/" class="mt-6 inline-block rounded-lg bg-brand px-6 py-3 text-sm font-semibold text-white hover:bg-brand-dark transition">
            Volver al inicio
        </a>
    </div>
</div>
