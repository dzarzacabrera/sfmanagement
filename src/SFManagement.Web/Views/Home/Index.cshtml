        <a class="flex items-center gap-2" href="/">
            <picture class="dark:hidden">
                <source srcset="~/img/skill_forge.webp" type="image/webp">
                <img src="~/img/skill_forge.png" alt="Skill Forge Management">
            </picture>
            <picture class="hidden dark:block">
                <source srcset="~/img/skill_forge_dark.webp" type="image/webp">
                <img src="~/img/skill_forge_dark.png" alt="Skill Forge Management">
            </picture>
        </a>
        <nav class="hidden items-center gap-8 md:flex">
            <a href="#features" class="text-sm text-gray-500 transition-colors hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100">Features</a>
            <a href="#how-it-works" class="text-sm text-gray-500 transition-colors hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100">How it works</a>
