    <!-- Why SFManagement -->
    <section id="features" class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
        <div class="mx-auto max-w-2xl text-center">
            <p class="text-sm font-semibold uppercase tracking-wide text-brand">Why SFManagement</p>
            <h2 class="mt-3 text-3xl font-semibold tracking-tight text-balance text-gray-900 sm:text-4xl dark:text-gray-100">Capital allocation without the black box</h2>
            <p class="mt-4 text-lg leading-relaxed text-gray-500 text-pretty dark:text-gray-400">High-dependency AI pipelines are replaced with deterministic linear algebra you can trust, reproduce, and explain.</p>
        </div>
        <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
            <div class="rounded-xl border border-gray-200 bg-white p-6 transition-colors hover:border-brand/40 dark:border-gray-700 dark:bg-gray-900">
                <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-brand/10 text-brand">
