@using SFManagement.Application.DTOs
@model ProjectDetailViewModel

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-3 sm:mb-4">
    <h1 class="text-2xl font-bold pt-2 text-brand dark:text-white">@Model.Name</h1>
    @if (Model.IsFinalized)
    {
        <span class="inline-flex items-center self-start sm:self-auto mt-3 sm:mt-0 px-3 py-1 rounded-full text-sm font-semibold bg-gray-100 text-gray-600 border border-gray-300 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600">
            Closed
        </span>
    }
    else
    {
        <span class="inline-flex items-center self-start sm:self-auto mt-3 sm:mt-0 px-3 py-1 rounded-full text-sm font-semibold bg-green-50 text-green-700 border border-green-300 dark:bg-green-900/30 dark:text-green-300 dark:border-green-700">
            In Progress
        </span>
    }
</div>

@section ActionButtons {
    <div class="flex items-center gap-2">
        <a href="/Dashboard/Index?projectId=@Model.IdEncrypted" class="bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep dark:bg-brand dark:hover:bg-brand-deep whitespace-nowrap">Dashboard</a>
        @if (!Model.IsFinalized)
        {
            <a href="/Project/Edit?projectId=@Model.IdEncrypted"
               class="inline-flex items-center gap-1.5 border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700 whitespace-nowrap">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                Edit
            </a>
        }
        <a href="/Project/Index" class="border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700 whitespace-nowrap">Back to Projects</a>
    </div>
}

<div class="mb-4">
    @if (!string.IsNullOrEmpty(Model.DescriptionMd))
    {
        <div class="bg-gray-50 pt-3 pb-4 pr-4 rounded-lg dark:bg-gray-800 dark:text-gray-300 text-sm whitespace-pre-wrap">@Model.DescriptionMd</div>
    }
    else
    {
        <p class="text-gray-400 italic dark:text-gray-400">No description.</p>
    }
</div>
@if (Model.IsFinalized)
{
    <div class="mb-6 p-4 rounded-lg bg-gray-50 border border-gray-200 text-gray-500 text-sm dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400">
        This project is closed. No further actions are available.
    </div>
}

@{
    var totalTasks = Model.Tasks?.Count ?? 0;
    var totalWorkers = Model.Workers?.Count ?? 0;
}

<div class="flex items-center justify-between mb-3">
    <h2 class="text-lg font-semibold dark:text-white">Tasks</h2>
    @if (!Model.IsFinalized)
    {
        <button onclick="openCreateTaskPopup('@Model.IdEncrypted')" class="bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep dark:bg-brand dark:hover:bg-brand-deep cursor-pointer">Add Task</button>
    }
</div>
@if (totalTasks > 0)
{
    <div id="project-tasks" class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3 mb-4">
        @for (int i = 0; i < totalTasks; i++)
        {
            var task = Model.Tasks![i];
            <div class="task-card bg-white rounded-xl border border-gray-200 shadow-sm p-4 hover:shadow-md transition-shadow dark:bg-gray-800 dark:border-gray-700 dark:text-gray-100 cursor-pointer"
                 data-pg-item
                 onclick="openTaskDetailPopup('@Model.IdEncrypted', '@task.IdEncrypted')">
                <div class="text-sm font-semibold text-gray-900 dark:text-gray-100">@task.Title</div>
                <div class="flex items-center gap-2 mt-1">
                    <span class="text-gray-700 font-medium" style="font-size:13px;">Priority:</span>
                    <span class="px-1.5 py-0.5 rounded-full text-xs font-semibold
                        @(task.Criticality == SFManagement.Domain.Enums.Criticality.Critical ? "bg-red-50 text-red-700 border border-red-300" :
                          task.Criticality == SFManagement.Domain.Enums.Criticality.High ? "bg-orange-50 text-orange-700 border border-orange-300" :
                          task.Criticality == SFManagement.Domain.Enums.Criticality.Medium ? "bg-blue-50 text-blue-700 border border-blue-300" :
                          "bg-gray-50 text-gray-600 border border-gray-300")">@task.Criticality</span>
                    <span class="text-gray-700 font-medium" style="font-size:13px;">Status:</span>
                    <span class="px-1.5 py-0.5 rounded-full text-xs font-semibold
                        @(task.Status == SFManagement.Domain.Enums.ProjectTaskStatus.InProgress ? "bg-amber-50 text-amber-700 border border-amber-300" :
                          task.Status == SFManagement.Domain.Enums.ProjectTaskStatus.InReview ? "bg-purple-50 text-purple-700 border border-purple-300" :
                          task.Status == SFManagement.Domain.Enums.ProjectTaskStatus.Finish ? "bg-green-50 text-green-700 border border-green-300" :
                          task.Status == SFManagement.Domain.Enums.ProjectTaskStatus.Archived ? "bg-gray-50 text-gray-600 border border-gray-300" :
                          "bg-blue-50 text-blue-700 border border-blue-300")">@task.Status</span>
                </div>
            </div>
        }
    </div>
    @await Html.PartialAsync("_Pagination", new PaginationViewModel(totalTasks, "tasks"), new ViewDataDictionary(ViewData) { { "PaginationGrid", "project-tasks" } })
}
else
{
    <p class="text-gray-400 italic dark:text-gray-400 mb-6">No tasks.</p>
}

<div class="flex items-center justify-between mb-3">
    <h2 class="text-lg font-semibold dark:text-white">Team</h2>
    @if (!Model.IsFinalized)
    {
        <button onclick="openCreateWorkerPopup('@Model.IdEncrypted')" class="bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep dark:bg-brand dark:hover:bg-brand-deep cursor-pointer">Add Worker</button>
    }
</div>
@if (totalWorkers > 0)
{
    <div id="project-workers" class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3 mb-4">
        @for (int i = 0; i < totalWorkers; i++)
        {
            var worker = Model.Workers![i];
            <div class="worker-card bg-white rounded-xl border border-gray-200 shadow-sm p-3 hover:shadow-md transition-shadow dark:bg-gray-800 dark:border-gray-700 dark:text-gray-100 cursor-pointer"
                 data-pg-item
                 onclick="openWorkerDetailPopup('@Model.IdEncrypted', '@worker.IdEncrypted', null)">
                <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 leading-tight truncate">@worker.Name</h3>
                        <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 truncate">@worker.Role</p>
                    </div>
                    <div class="shrink-0 text-right text-[13px] sm:text-[11px] text-gray-500 dark:text-gray-500">
                        @worker.ActiveTaskCount active task@(worker.ActiveTaskCount == 1 ? "" : "s")<br>
                        @worker.EvaluationCount evaluations
                    </div>
                </div>
            </div>
        }
    </div>
    @await Html.PartialAsync("_Pagination", new PaginationViewModel(totalWorkers, "workers"), new ViewDataDictionary(ViewData) { { "PaginationGrid", "project-workers" } })
}
else
{
    <p class="text-gray-400 italic dark:text-gray-400 mb-6">No workers assigned.</p>
}

