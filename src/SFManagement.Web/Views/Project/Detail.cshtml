@model ProjectDetailViewModel

<h1 class="text-2xl font-bold mb-6 dark:text-white">@Model.Name</h1>

<div class="prose prose-sm max-w-none mb-6">
    @if (!string.IsNullOrEmpty(Model.DescriptionMd))
    {
        <pre class="bg-gray-50 p-4 rounded-lg text-xs font-mono whitespace-pre-wrap dark:bg-gray-800 dark:text-gray-300">@Model.DescriptionMd</pre>
    }
    else
    {
        <p class="text-gray-400 italic dark:text-gray-400">No description.</p>
    }
</div>

<a href="/Task/Create?projectId=@Model.Id"
   class="bg-brand text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-brand-deep dark:bg-brand dark:hover:bg-brand-deep">
    Add Task
</a>
