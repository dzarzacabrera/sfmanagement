@using SFManagement.Application.DTOs
@model ProjectDetailViewModel

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4 sm:mb-6">
    <h1 class="text-2xl font-bold text-brand dark:text-white">@Model.Name</h1>
    @if (Model.IsFinalized)
    {
        <span class="inline-flex items-center self-start sm:self-auto mt-3 sm:mt-0 px-3 py-1 rounded-full text-sm font-semibold bg-gray-100 text-gray-600 border border-gray-300 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600">
            Closed
        </span>
    }
    else
    {
        <span class="inline-flex items-center self-start sm:self-auto mt-3 sm:mt-0 px-3 py-1 rounded-full text-sm font-semibold bg-green-50 text-green-700 border border-green-300 dark:bg-green-900/30 dark:text-green-300 dark:border-green-700">
            In Progress
        </span>
    }
</div>

@section ActionButtons {
    <a href="/Project/Index" class="border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">Back to Projects</a>
}

<div class="prose prose-sm max-w-none mb-6">
    @if (!string.IsNullOrEmpty(Model.DescriptionMd))
    {
        var html = Markdig.Markdown.ToHtml(Model.DescriptionMd);
        <div class="bg-gray-50 pt-3 pb-4 pr-4 rounded-lg dark:bg-gray-800 dark:text-gray-300">@Html.Raw(html)</div>
    }
    else
    {
        <p class="text-gray-400 italic dark:text-gray-400">No description.</p>
    }
</div>
@if (Model.IsFinalized)
{
    <div class="mb-6 p-4 rounded-lg bg-gray-50 border border-gray-200 text-gray-500 text-sm dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400">
        This project is closed. No further actions are available.
    </div>
}

@if (Model.Tasks?.Count > 0)
{
    var totalTasks = Model.Tasks.Count;
    var md = 6; var mm = 4;

    <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-semibold dark:text-white">Tasks</h2>
        @if (!Model.IsFinalized)
        {
            <a href="/Task/Create?projectId=@Model.IdEncrypted" class="bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep dark:bg-brand dark:hover:bg-brand-deep">Add Task</a>
        }
    </div>
    <div id="project-tasks" class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3 mb-4">
        @for (int i = 0; i < totalTasks; i++)
        {
            var hiddenClass = i >= md ? "hidden" : i >= mm ? "hidden sm:block" : "";
            var task = Model.Tasks[i];
            <div class="task-card bg-white rounded-xl border border-gray-200 shadow-sm p-4 hover:shadow-md transition-shadow dark:bg-gray-800 dark:border-gray-700 dark:text-gray-100 cursor-pointer @hiddenClass"
                 data-index="@i"
                 onclick="window.location='/Task/Detail?taskId=@task.IdEncrypted'">
                <div class="text-sm font-semibold text-gray-900 dark:text-gray-100">@task.Title</div>
                <div class="flex items-center gap-2 mt-1">
                    <span class="text-xs text-gray-500 dark:text-gray-400 font-medium">Priority:</span>
                    <span class="px-1.5 py-0.5 rounded-full text-xs font-medium
                        @(task.Criticality == SFManagement.Domain.Enums.Criticality.Critical ? "bg-red-100 text-red-700" :
                          task.Criticality == SFManagement.Domain.Enums.Criticality.High ? "bg-orange-100 text-orange-700" :
                          task.Criticality == SFManagement.Domain.Enums.Criticality.Medium ? "bg-blue-100 text-blue-700" :
                          "bg-gray-100 text-gray-600")">@task.Criticality</span>
                    <span class="text-xs text-gray-500 dark:text-gray-400 font-medium">Status:</span>
                    <span class="px-1.5 py-0.5 rounded-full text-xs font-medium
                        @(task.Status == SFManagement.Domain.Enums.ProjectTaskStatus.InProgress ? "bg-amber-100 text-amber-700" :
                          task.Status == SFManagement.Domain.Enums.ProjectTaskStatus.Blocked ? "bg-red-100 text-red-700" :
                          task.Status == SFManagement.Domain.Enums.ProjectTaskStatus.Finish ? "bg-green-100 text-green-700" :
                          task.Status == SFManagement.Domain.Enums.ProjectTaskStatus.Archived ? "bg-gray-100 text-gray-500" :
                          "bg-blue-100 text-blue-700")">@task.Status</span>
                </div>
            </div>
        }
    </div>
    if (totalTasks > md)
    {
        <button onclick="toggleSection('project-tasks', 6, 4, this)" class="toggle-btn text-sm font-medium text-brand hover:text-brand-deep mb-6" data-total="@totalTasks" data-label="tasks">+ tasks</button>
    }
}

@if (Model.Workers?.Count > 0)
{
    var totalWorkers = Model.Workers.Count;
    var md = 6; var mm = 4;

    <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-semibold dark:text-white">Team</h2>
        @if (!Model.IsFinalized)
        {
            <a href="/Worker/Create?projectId=@Model.IdEncrypted" class="bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep dark:bg-brand dark:hover:bg-brand-deep">Add Worker</a>
        }
    </div>
    <div id="project-workers" class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3 mb-4">
        @for (int i = 0; i < totalWorkers; i++)
        {
            var hiddenClass = i >= md ? "hidden" : i >= mm ? "hidden sm:block" : "";
            var worker = Model.Workers[i];
            <div class="worker-card bg-white rounded-xl border border-gray-200 shadow-sm p-4 hover:shadow-md transition-shadow dark:bg-gray-800 dark:border-gray-700 dark:text-gray-100 cursor-pointer @hiddenClass"
                 data-index="@i"
                 onclick="window.location='/Worker/Detail?workerId=@worker.IdEncrypted'">
                <div class="flex items-center justify-between">
                    <div>
                        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100">@worker.Name</h3>
                        <p class="text-sm text-gray-400 dark:text-gray-400">@worker.Role</p>
                    </div>
                </div>
                <div class="flex gap-3 mt-3 text-sm text-gray-500 dark:text-gray-400">
                    <span>@worker.ActiveTaskCount active tasks</span>
                    <span>@worker.EvaluationCount evaluations</span>
                </div>
            </div>
        }
    </div>
    if (totalWorkers > md)
    {
        <button onclick="toggleSection('project-workers', 6, 4, this)" class="toggle-btn text-sm font-medium text-brand hover:text-brand-deep mb-6" data-total="@totalWorkers" data-label="workers">+ workers</button>
    }
}
else
{
    <div class="text-center py-8">
        <p class="text-gray-400 dark:text-gray-500">No workers assigned to this project yet.</p>
    </div>
}

<script>
function initToggleButtons() {
    var isMobile = window.innerWidth < 640;
    document.querySelectorAll('.toggle-btn').forEach(function (btn) {
        if (btn.dataset.expanded !== 'true') {
            var total = parseInt(btn.dataset.total);
            var limit = isMobile ? 4 : 6;
            btn.textContent = '+ ' + (total - limit) + ' ' + btn.dataset.label;
        }
    });
}

function toggleSection(gridId, maxDesktop, maxMobile, btn) {
    var grid = document.getElementById(gridId);
    var isExpanded = grid.dataset.expanded === 'true';
    var cards = grid.querySelectorAll('.task-card, .worker-card');
    var total = cards.length;

    cards.forEach(function (c) {
        var idx = parseInt(c.dataset.index);
        c.classList.remove('hidden', 'sm:block');
        if (isExpanded) {
            if (idx >= maxDesktop) {
                c.classList.add('hidden');
            } else if (idx >= maxMobile) {
                c.classList.add('hidden', 'sm:block');
            }
        }
    });

    grid.dataset.expanded = isExpanded ? 'false' : 'true';
    btn.dataset.expanded = isExpanded ? 'false' : 'true';
    var limit = window.innerWidth < 640 ? maxMobile : maxDesktop;
    btn.textContent = isExpanded ? '+ ' + (total - limit) + ' ' + btn.dataset.label : 'Show Less';
}

document.addEventListener('DOMContentLoaded', initToggleButtons);
</script>
