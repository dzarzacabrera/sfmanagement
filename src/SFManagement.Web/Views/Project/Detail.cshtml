@using SFManagement.Application.DTOs
@model ProjectDetailViewModel

<h1 class="text-2xl font-bold mb-6 text-brand dark:text-white">@Model.Name</h1>

<div class="prose prose-sm max-w-none mb-6">
    @if (!string.IsNullOrEmpty(Model.DescriptionMd))
    {
        <pre class="bg-gray-50 p-4 rounded-lg text-sm font-mono whitespace-pre-wrap dark:bg-gray-800 dark:text-gray-300">@Model.DescriptionMd</pre>
    }
    else
    {
        <p class="text-gray-400 italic dark:text-gray-400">No description.</p>
    }
</div>

<div class="flex items-center gap-2 mb-6">
    <a href="/Task/Create?projectId=@Model.IdEncrypted"
       class="bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep dark:bg-brand dark:hover:bg-brand-deep">
        Add Task
    </a>
    <button onclick="openAddWorkerPopup('@Model.IdEncrypted')"
            class="border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
        Add Worker
    </button>
</div>

@if (Model.Workers?.Count > 0)
{
    <h2 class="text-lg font-semibold mb-3 dark:text-white">Workers in this project</h2>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        @foreach (var worker in Model.Workers)
        {
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 hover:shadow-md transition-shadow dark:bg-gray-800 dark:border-gray-700 dark:text-gray-100">
                <div class="flex items-center justify-between">
                    <div>
                        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100">@worker.Name</h3>
                        <p class="text-sm text-gray-400 dark:text-gray-400">@worker.Role</p>
                    </div>
                    <a href="/Worker/Detail?workerId=@worker.IdEncrypted"
                       class="text-sm font-medium text-brand hover:text-brand-deep">View</a>
                </div>
                <div class="flex gap-3 mt-3 text-sm text-gray-500 dark:text-gray-400">
                    <span>@worker.ActiveTaskCount active tasks</span>
                    <span>@worker.EvaluationCount evaluations</span>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-8">
        <p class="text-gray-400 dark:text-gray-500">No workers assigned to this project yet.</p>
    </div>
}
