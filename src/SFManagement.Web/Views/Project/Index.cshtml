@model IReadOnlyList<ProjectDto>

<h1 class="text-2xl font-bold pt-2 mb-6 text-brand dark:text-white">Projects</h1>

@section ActionButtons {
    <a href="/Project/Create"
       class="bg-brand dark:bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep dark:hover:bg-brand-deep">
        + New Project
    </a>
}

@if (Model.Count > 0)
{
<div class="flex mb-6">
    <div class="flex items-stretch flex-1">
        <div class="relative flex-1 min-w-0">
            <input type="text" id="projectSearch"
                   class="w-full border border-gray-300 rounded-lg xl:rounded-l-lg xl:rounded-tr-none xl:rounded-br-none px-4 py-2.5 pr-8 text-sm focus-visible:outline-none focus-visible:border-blue-500 focus-visible:ring-4 focus-visible:ring-[#96c0d9] dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100 dark:placeholder-gray-400"
                   placeholder="Search projects...">
            <button type="button" id="clearSearch"
                    class="hidden absolute right-2 top-1/2 -translate-y-1/2 p-0.5 rounded text-gray-400 hover:text-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 dark:hover:text-gray-200 transition-colors"
                    aria-label="Clear search">
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
        <div class="hidden xl:flex border border-l-0 border-gray-300 rounded-r-lg overflow-hidden dark:border-gray-600">
            <button type="button" id="viewList"
                    class="p-2.5 transition-colors text-gray-500 hover:bg-gray-50 dark:text-gray-400 dark:hover:bg-gray-700 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9] relative z-10"
                    title="List view">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
            <div class="w-px bg-gray-300 dark:bg-gray-600 shrink-0"></div>
            <button type="button" id="viewCards"
                    class="p-2.5 transition-colors bg-blue-50 text-brand focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9] relative z-10"
                    title="Card view">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                </svg>
            </button>
        </div>
    </div>
</div>
}

@if (Model.Count == 0)
{
    <div class="text-center py-12">
        <p class="text-gray-400 mb-4 dark:text-gray-500">No projects yet.</p>
        <a href="/Project/Create"
           class="bg-brand text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-brand-deep">
            Create your first project
        </a>
    </div>
}
else
{
    <div id="projectGridWrapper">
    <div id="projectCards" class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        @foreach (var project in Model)
        {
            <div class="project-card bg-white rounded-xl border border-gray-200 shadow-sm p-5 hover:shadow-md transition-shadow cursor-pointer dark:bg-gray-800 dark:border-gray-700 dark:text-gray-100 relative flex flex-col justify-between"
                 data-pg-item
                 data-name="@project.Name.ToLower()"
                 onclick="location.href='/Dashboard/Index?projectId=@project.IdEncrypted'">
                @if (!project.IsFinalized)
                {
                    <a href="/Project/Edit?projectId=@project.IdEncrypted"
                       class="absolute top-3 right-3 w-10 h-10 flex items-center justify-center rounded-lg text-gray-400 hover:text-brand hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9]"
                       onclick="event.stopPropagation()"
                       aria-label="Edit @project.Name">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                        </svg>
                    </a>
                }
                <div>
                    <h2 class="text-[16px] font-semibold text-gray-900 dark:text-gray-100 pr-12">@project.Name</h2>
                    <div class="flex items-center gap-2 mt-1">
                        <span class="text-gray-700 dark:text-gray-400 font-medium" style="font-size:13px;">Status:</span>
                        @if (project.IsFinalized)
                        {
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-600 border border-gray-300 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600">
                                Closed
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-green-50 text-green-700 border border-green-300 dark:bg-green-900/30 dark:text-green-300 dark:border-green-700">
                                In Progress
                            </span>
                        }
                    </div>
                    @if (project.WorkerNames?.Count > 0)
                    {
                        <div class="mt-3 text-sm text-gray-500 dark:text-gray-400 line-clamp-3" data-tooltip="@string.Join(", ", project.WorkerNames)">
                            <span class="font-semibold text-gray-700 dark:text-gray-300">Team:</span>
                            @string.Join(", ", project.WorkerNames)
                        </div>
                    }
                </div>
                <div class="flex flex-wrap gap-2 pt-3">
                    @if (!project.IsFinalized)
                    {
                        <a href="/Project/Detail?projectId=@project.IdEncrypted"
                           class="bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep whitespace-nowrap"
                           onclick="event.stopPropagation()">
                            Detail
                        </a>
                        <button onclick="event.stopPropagation(); openCreateTaskPopup('@project.IdEncrypted')"
                                class="border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700 whitespace-nowrap cursor-pointer">
                            + Task
                        </button>
                        <button onclick="event.stopPropagation(); openCreateWorkerPopup('@project.IdEncrypted')"
                                class="border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700 whitespace-nowrap cursor-pointer">
                            + Worker
                        </button>
                        <button onclick="event.stopPropagation(); finalizeProject('@project.IdEncrypted', this)"
                                class="border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700 transition-colors cursor-pointer whitespace-nowrap">
                            Close
                        </button>
                    }
                </div>
            </div>
        }
    </div>

    <div id="projectList" class="hidden">
        <div class="rounded-xl border border-gray-200 shadow-sm bg-white overflow-hidden dark:bg-gray-800 dark:border-gray-700">
            <div class="hidden sm:grid sm:grid-cols-12 items-center gap-4 py-2.5 px-4 border-b border-gray-100 dark:border-gray-700">
                <div class="col-span-4 text-xs font-semibold text-gray-400 tracking-wider uppercase">Project</div>
                <div class="col-span-2 text-xs font-semibold text-gray-400 tracking-wider uppercase">Status</div>
                <div class="col-span-3 text-xs font-semibold text-gray-400 tracking-wider uppercase">Team</div>
                <div class="col-span-3 text-xs font-semibold text-gray-400 tracking-wider uppercase text-right">Actions</div>
            </div>
            @foreach (var project in Model)
            {
                <div class="project-row grid grid-cols-1 sm:grid-cols-12 gap-1 sm:gap-4 border-b border-gray-100 last:border-b-0 py-2 sm:py-3 px-3 sm:px-4 hover:bg-gray-50 dark:border-gray-700 dark:hover:bg-gray-800 transition-colors cursor-pointer"
                     data-pg-item
                     data-name="@project.Name.ToLower()"
                 onclick="location.href='/Dashboard/Index?projectId=@project.IdEncrypted'">
                    <div class="sm:col-span-4 font-semibold text-gray-900 dark:text-gray-100 text-sm truncate" data-tooltip="@project.Name">
                        @project.Name
                    </div>
                    <div class="sm:col-span-2">
                        @if (project.IsFinalized)
                        {
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-600 border border-gray-300 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600">
                                Closed
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-green-50 text-green-700 border border-green-300 dark:bg-green-900/30 dark:text-green-300 dark:border-green-700">
                                In Progress
                            </span>
                        }
                    </div>
                    <div class="sm:col-span-3 text-sm text-gray-500 dark:text-gray-300 truncate" data-tooltip="@(project.WorkerNames?.Count > 0 ? "Team: " + string.Join(", ", project.WorkerNames) : "")">
                        @if (project.WorkerNames?.Count > 0)
                        {
                            <span class="font-semibold text-gray-700 dark:text-gray-300">Team:</span> @string.Join(", ", project.WorkerNames)
                        }
                        else
                        {
                            <span class="text-gray-400 italic">—</span>
                        }
                    </div>
                    <div class="sm:col-span-3 flex items-center justify-end" onclick="event.stopPropagation()">
                        @if (!project.IsFinalized)
                        {
                            <div class="flex items-center gap-1 pr-2 border-r border-gray-200 dark:border-gray-600">
                                <a href="/Project/Detail?projectId=@project.IdEncrypted"
                                   class="p-2 rounded-lg text-blue-400 hover:text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9]"
                                   title="View details">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                    </svg>
                                </a>
                                <button onclick="openCreateTaskPopup('@project.IdEncrypted')"
                                        class="p-2 rounded-lg text-green-400 hover:text-green-600 hover:bg-green-50 dark:hover:bg-green-900/20 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9]"
                                        title="Add task">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                                    </svg>
                                </button>
                                <button onclick="openCreateWorkerPopup('@project.IdEncrypted')"
                                        class="p-2 rounded-lg text-purple-400 hover:text-purple-600 hover:bg-purple-50 dark:hover:bg-purple-900/20 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9]"
                                        title="Add worker">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                                    </svg>
                                </button>
                            </div>
                            <div class="flex items-center gap-1 pl-2">
                                <a href="/Project/Edit?projectId=@project.IdEncrypted"
                                   class="p-2 rounded-lg text-amber-400 hover:text-amber-600 hover:bg-amber-50 dark:hover:bg-amber-900/20 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9]"
                                   title="Edit">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                                    </svg>
                                </a>
                            </div>
                            <div class="flex items-center gap-1 pl-2">
                                <button onclick="finalizeProject('@project.IdEncrypted', this)"
                                        class="p-2 rounded-lg text-gray-500 hover:text-gray-700 hover:bg-gray-100 dark:text-gray-400 dark:hover:text-gray-200 dark:hover:bg-gray-700 transition-colors cursor-pointer focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9]"
                                        title="Close">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                                </button>
                            </div>
                        }
                        else
                        {
                            <a href="/Project/Detail?projectId=@project.IdEncrypted"
                               class="p-2 rounded-lg text-blue-400 hover:text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#96c0d9]"
                               title="View details">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

    <div id="emptyState" class="hidden text-center py-12">
        <p class="text-gray-400 dark:text-gray-500">No projects match your search.</p>
    </div>

    @await Html.PartialAsync("_Pagination", new PaginationViewModel(Model.Count, "projects"), new ViewDataDictionary(ViewData) { { "PaginationGrid", "projectGridWrapper" } })
}

<script>
    function switchToCards() {
        document.getElementById('projectCards').classList.remove('hidden');
        document.getElementById('projectList').classList.add('hidden');
        document.getElementById('viewCards').className = 'p-2.5 transition-colors bg-blue-50 text-brand';
        document.getElementById('viewList').className = 'p-2.5 transition-colors text-gray-500 hover:bg-gray-50 dark:text-gray-400 dark:hover:bg-gray-700';
        localStorage.setItem('projectViewMode', 'cards');
        window.paginationReRender('projectGridWrapper');
    }

    function switchToList() {
        document.getElementById('projectCards').classList.add('hidden');
        document.getElementById('projectList').classList.remove('hidden');
        document.getElementById('viewList').className = 'p-2.5 transition-colors bg-blue-50 text-brand';
        document.getElementById('viewCards').className = 'p-2.5 transition-colors text-gray-500 hover:bg-gray-50 dark:text-gray-400 dark:hover:bg-gray-700';
        localStorage.setItem('projectViewMode', 'list');
        window.paginationReRender('projectGridWrapper');
    }

    var searchInput = document.getElementById('projectSearch');
    var clearBtn = document.getElementById('clearSearch');
    if (searchInput && clearBtn) {
        function applySearch() {
            var q = searchInput.value.toLowerCase().trim();
            localStorage.setItem('projectSearchQuery', searchInput.value);
            var items = document.querySelectorAll('.project-card, .project-row');
            var hidden = 0;
            items.forEach(function (el) {
                var match = !q || el.dataset.name.includes(q);
                el.dataset.pgFiltered = match ? '' : 'true';
                if (!match) hidden++;
            });
            document.getElementById('emptyState').classList.toggle('hidden', hidden !== items.length);
            clearBtn.classList.toggle('hidden', !q);
        }
        searchInput.addEventListener('input', function () {
            applySearch();
            // Reset to page 1 on new search
            window.paginationRefresh('projectGridWrapper');
        });
        clearBtn.addEventListener('click', function () {
            searchInput.value = '';
            localStorage.setItem('projectSearchQuery', '');
            applySearch();
            window.paginationRefresh('projectGridWrapper');
            searchInput.focus();
        });
    }

    document.getElementById('viewCards')?.addEventListener('click', function () {
        if (document.getElementById('projectCards').classList.contains('hidden')) {
            switchToCards();
        }
    });
    document.getElementById('viewList')?.addEventListener('click', function () {
        if (document.getElementById('projectList').classList.contains('hidden')) {
            switchToList();
        }
    });

    var mql = window.matchMedia('(max-width: 1199px)');
    mql.addEventListener('change', function (e) {
        if (e.matches) {
            if (document.getElementById('projectList') && !document.getElementById('projectList').classList.contains('hidden')) {
                switchToCards();
            }
        }
    });

    document.addEventListener('DOMContentLoaded', function () {
        var savedView = localStorage.getItem('projectViewMode');
        var savedQuery = localStorage.getItem('projectSearchQuery');

        if (savedView === 'list' && !mql.matches) {
            switchToList();
        } else {
            if (mql.matches) switchToCards();
        }

        if (savedQuery && searchInput) {
            searchInput.value = savedQuery;
            var evt = new Event('input', { bubbles: true });
            searchInput.dispatchEvent(evt);
        }
    });
</script>
