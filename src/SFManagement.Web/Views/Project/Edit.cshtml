@model ProjectDto

<h1 class="text-2xl font-bold mb-6 dark:text-white">Edit Project</h1>

<form method="post" class="max-w-lg space-y-4">
    <input type="hidden" name="projectId" value="@Model.Id">

    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300">Project Name</label>
        <input type="text" name="name" value="@Model.Name" required
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-brand focus:border-brand dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100">
    </div>
    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300">Description</label>
        <textarea name="descriptionMd" rows="6"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-brand focus:border-brand dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100 font-mono">@Model.DescriptionMd</textarea>
    </div>
    <button type="submit"
            class="bg-brand text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-brand-deep">
        Save Changes
    </button>
</form>
