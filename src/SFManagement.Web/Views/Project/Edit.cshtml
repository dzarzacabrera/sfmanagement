@model ProjectDto

<h1 class="text-2xl font-bold pt-2 mb-6 text-brand dark:text-white">Edit Project</h1>

@section ActionButtons {
    <a href="/Project/Index"
       class="border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
        Back to Projects
    </a>
}

<form method="post" class="max-w-lg space-y-4">
    <input type="hidden" name="projectIdEncrypted" value="@Model.IdEncrypted">

    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300">Project Name <span class="text-red-500">*</span></label>
        <input type="text" name="name" value="@Model.Name" required
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus-visible:outline-none focus-visible:border-blue-500 focus-visible:ring-4 focus-visible:ring-[#96c0d9] dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100">
    </div>
    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1 dark:text-gray-300">Description</label>
        <textarea name="descriptionMd" rows="6"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus-visible:outline-none focus-visible:border-blue-500 focus-visible:ring-4 focus-visible:ring-[#96c0d9] dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100 font-mono">@Model.DescriptionMd</textarea>
    </div>
    <div class="flex gap-3">
        <button type="submit"
                class="bg-brand text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep border border-transparent">
            Save Changes
        </button>
        <a href="/Project/Index"
           class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-300 text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
            Cancel
        </a>
    </div>
</form>
