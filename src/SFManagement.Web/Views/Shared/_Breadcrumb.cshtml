@{
    var crumbs = ViewBag.Breadcrumbs as IReadOnlyList<KeyValuePair<string, string>>;
    if (crumbs is not null && crumbs.Count > 0)
    {
        <nav class="text-sm text-gray-400 mb-4 flex items-center gap-1.5 flex-wrap">
            <a href="/" class="hover:text-brand transition-colors">Home</a>
            @foreach (var crumb in crumbs)
            {
                <span class="text-gray-300">/</span>
                if (!string.IsNullOrEmpty(crumb.Value))
                {
                    <a href="@crumb.Value" class="hover:text-brand transition-colors">@crumb.Key</a>
                }
                else
                {
                    <span class="text-gray-500 font-medium">@crumb.Key</span>
                }
            }
        </nav>
    }
}
