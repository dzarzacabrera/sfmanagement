@model SFManagement.Web.ViewModels.SkillsEvolutionViewModel

<div class="flex flex-col h-full" id="evoPopupRoot">
<textarea id="evoRawData" class="hidden">@Model.EvaluationsJson</textarea>

<div class="shrink-0 px-6 pt-6 pb-3 border-b border-gray-100 dark:border-gray-700">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white leading-tight truncate mb-1">@Model.WorkerName Skills Evolution</h2>
</div>

<div class="flex-1 overflow-y-auto px-6 py-4">
    <div class="flex flex-wrap items-end gap-3 mb-4">
        <div>
            <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">From</label>
            <input type="date" id="evoDateFrom"
                   class="h-[38px] border border-gray-300 rounded-lg px-3 py-1.5 text-sm dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100 focus-visible:outline-none focus-visible:border-blue-500 focus-visible:ring-4 focus-visible:ring-[#96c0d9]">
        </div>
        <div>
            <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">To</label>
            <input type="date" id="evoDateTo"
                   class="h-[38px] border border-gray-300 rounded-lg px-3 py-1.5 text-sm dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100 focus-visible:outline-none focus-visible:border-blue-500 focus-visible:ring-4 focus-visible:ring-[#96c0d9]">
        </div>
        <button id="evoApplyFilter" type="button"
                class="h-[38px] bg-brand text-white px-4 py-1.5 rounded-lg text-sm font-medium hover:bg-brand-deep transition-colors cursor-pointer">
            Filter
        </button>
        <div class="flex gap-1.5 ml-1">
            <button type="button" data-range="180"
                    class="evo-quick-btn h-[38px] border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700 transition-colors cursor-pointer whitespace-nowrap">
                180 days
            </button>
            <button type="button" data-range="365"
                    class="evo-quick-btn h-[38px] border border-gray-300 text-gray-700 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700 transition-colors cursor-pointer whitespace-nowrap">
                365 days
            </button>
        </div>
    </div>

    <div class="relative max-sm:h-[280px] sm:h-[380px]">
        <canvas id="evoChart"></canvas>
    </div>

    <div id="evoLegend" class="flex flex-wrap gap-2 mt-4 pt-4 border-t border-gray-100 dark:border-gray-700"></div>
</div>

<div class="flex justify-end px-6 pb-4 pt-3 shrink-0 border-t border-gray-100 dark:border-gray-700">
    <button type="button" onclick="closeModal()"
            class="px-4 py-2 text-sm rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
        Close
    </button>
</div>
</div>
