@model IReadOnlyList<SkillDto>
@using System.Text.Json

@{
    var skillsJson = JsonSerializer.Serialize(Model.Select(s => new { id = s.Id, name = s.Name, vectorPosition = s.VectorPosition, isActive = s.IsActive }));
}

<div class="skill-selector" data-field-prefix="@(ViewBag.SkillFieldPrefix ?? "")" data-skills='@skillsJson' data-initial-skills='@(ViewBag.InitialSkillsJson ?? "[]")'>
    <input type="text" class="skill-filter w-full border border-gray-300 rounded-lg px-3 py-2 text-sm mb-3 focus-visible:outline-none focus-visible:border-blue-500 focus-visible:ring-4 focus-visible:ring-[#96c0d9] dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100 dark:placeholder-gray-400"
           placeholder="Search skills...">

    <div class="skill-unselected flex flex-wrap gap-2 mb-4 min-h-[40px] bg-gray-50 rounded-lg p-1 dark:bg-gray-800">
    </div>

    <div class="border-t border-gray-200 pt-3 dark:border-gray-700">
        <p class="text-sm font-medium text-gray-500 mb-2 dark:text-gray-400">Selected</p>
        <div class="skill-selected grid grid-cols-2 gap-2">
        </div>
    </div>
</div>

<script src="~/js/skill-selector.js"></script>
