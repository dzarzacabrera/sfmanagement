@model SFManagement.Web.ViewModels.EvaluationDetailViewModel
@using SFManagement.Domain.Enums

@{
    var improvedPct = Model.TotalSkills > 0 ? (int)Math.Round((double)Model.Improved / Model.TotalSkills * 100) : 0;
    var decreasedPct = Model.TotalSkills > 0 ? (int)Math.Round((double)Model.Decreased / Model.TotalSkills * 100) : 0;
    var unchangedPct = Model.TotalSkills > 0 ? (int)Math.Round((double)Model.Unchanged / Model.TotalSkills * 100) : 0;
}

<div class="flex flex-col h-full">
<div class="shrink-0 px-6 pt-6 pb-3 border-b border-gray-100 dark:border-gray-700">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white leading-tight truncate mb-2">@Model.TaskTitle</h2>
    <div class="flex items-center gap-2 flex-wrap">
        <span class="text-gray-700 font-medium" style="font-size:13px;">Priority:</span>
        <span class="px-1.5 py-0.5 rounded-full text-xs font-semibold
            @(Model.Criticality == Criticality.Critical ? "bg-red-50 text-red-700 border border-red-300" :
              Model.Criticality == Criticality.High ? "bg-orange-50 text-orange-700 border border-orange-300" :
              Model.Criticality == Criticality.Medium ? "bg-blue-50 text-blue-700 border border-blue-300" :
              "bg-gray-50 text-gray-600 border border-gray-300")">@Model.Criticality</span>
        <span class="text-gray-700 font-medium" style="font-size:13px;">Status:</span>
        <span class="px-1.5 py-0.5 rounded-full text-xs font-semibold
            @(Model.Status == ProjectTaskStatus.InProgress ? "bg-amber-50 text-amber-700 border border-amber-300" :
              Model.Status == ProjectTaskStatus.InReview ? "bg-purple-50 text-purple-700 border border-purple-300" :
              Model.Status == ProjectTaskStatus.Finish ? "bg-green-50 text-green-700 border border-green-300" :
              Model.Status == ProjectTaskStatus.Archived ? "bg-gray-50 text-gray-600 border border-gray-300" :
              "bg-blue-50 text-blue-700 border border-blue-300")">@Model.Status</span>
    </div>
    <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4 mt-2">
        <span class="flex items-center gap-1.5">
            <span class="text-gray-700 font-medium" style="font-size:13px;">Date:</span>
            <span class="text-sm text-gray-500 dark:text-gray-400">@Model.EvaluatedAt.ToString("dd/MM/yyyy HH:mm")</span>
        </span>
        <span class="flex items-center gap-1.5">
            <span class="text-gray-700 font-medium" style="font-size:13px;">Project:</span>
            <span class="text-sm text-gray-500 dark:text-gray-400">@Model.ProjectName</span>
        </span>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mt-3">
        <div class="rounded-lg border border-gray-200 dark:border-gray-700 px-3 py-2">
            <div class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider">Total Impact</div>
            <div class="font-mono text-sm font-semibold tabular-nums mt-0.5 @(Model.TotalImpact > 0 ? "text-green-600" : Model.TotalImpact < 0 ? "text-red-600" : "text-gray-400")">
                @if (Model.TotalImpact > 0)
                {
                    <span>▲</span>
                }
                else if (Model.TotalImpact < 0)
                {
                    <span>▼</span>
                }
                else
                {
                    <span style="font-size:0.6rem">◀▶</span>
                }
                @Model.TotalImpact.ToString("+0.00;-0.00")
            </div>
        </div>
        <div class="rounded-lg border border-gray-200 dark:border-gray-700 px-3 py-2">
            <div class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider">Improved</div>
            <div class="font-mono text-sm font-semibold tabular-nums mt-0.5 text-green-600">▲ @Model.Improved (@improvedPct%)</div>
        </div>
        <div class="rounded-lg border border-gray-200 dark:border-gray-700 px-3 py-2">
            <div class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider">Decreased</div>
            <div class="font-mono text-sm font-semibold tabular-nums mt-0.5 text-red-600">▼ @Model.Decreased (@decreasedPct%)</div>
        </div>
        <div class="rounded-lg border border-gray-200 dark:border-gray-700 px-3 py-2">
            <div class="text-[11px] font-semibold text-gray-400 uppercase tracking-wider">Unchanged</div>
            <div class="font-mono text-sm font-semibold tabular-nums mt-0.5 text-gray-400">■ @Model.Unchanged (@unchangedPct%)</div>
        </div>
    </div>
</div>

<div class="flex-1 overflow-y-auto px-6 py-4">
    <table class="w-full text-sm dark:text-gray-100">
        <thead>
            <tr class="text-left border-b border-gray-200 dark:border-gray-700">
                <th class="pb-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">Skill</th>
                @if (!Model.IsManualAdjustment)
                {
                    <th class="pb-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">Evaluation Score</th>
                }
                <th class="pb-2 text-xs font-semibold text-gray-400 uppercase tracking-wider text-center">Previous</th>
                <th class="pb-2 text-xs font-semibold text-gray-400 uppercase tracking-wider text-center">New</th>
                <th class="pb-2 text-xs font-semibold text-gray-400 uppercase tracking-wider text-center">Impact</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var skill in Model.Skills)
            {
                var pct = Math.Clamp(skill.Rating / 10.0 * 100, 0, 100);
                <tr class="border-b border-gray-100 dark:border-gray-700/50 last:border-b-0">
                    <td class="py-2.5 pr-3 text-gray-700 dark:text-gray-300 font-medium whitespace-nowrap">@skill.SkillName</td>
                    @if (!Model.IsManualAdjustment)
                    {
                        <td class="py-2.5 pr-3">
                            <div class="flex items-center gap-2">
                                <div class="flex-1 flex h-2 rounded-full overflow-hidden bg-gray-200 dark:bg-gray-700">
                                    <div class="h-full bg-brand-dark rounded-l-full" style="width:@pct%"></div>
                                    <div class="h-full bg-gray-200 dark:bg-gray-700 flex-1"></div>
                                </div>
                                <span class="font-mono text-xs tabular-nums text-gray-700 dark:text-gray-300 w-10 text-right">@skill.Rating.ToString("0.00")</span>
                            </div>
                        </td>
                    }
                    <td class="py-2.5 px-2 font-mono text-xs tabular-nums text-center text-gray-500 dark:text-gray-400">@skill.PreviousLevel.ToString("0.00")</td>
                    <td class="py-2.5 px-2 font-mono text-xs tabular-nums text-center text-gray-700 dark:text-gray-300 font-medium">@skill.NewLevel.ToString("0.00")</td>
                    <td class="py-2.5 pl-2 font-mono text-xs tabular-nums text-center @(skill.Impact > 0 ? "text-green-600" : skill.Impact < 0 ? "text-red-600" : "text-gray-400")">
                        @if (skill.Impact > 0)
                        {
                            <span>▲</span>
                        }
                        else if (skill.Impact < 0)
                        {
                            <span>▼</span>
                        }
                        else
                        {
                            <span style="font-size:0.6rem">◀▶</span>
                        }
                        @skill.Impact.ToString("+0.00;-0.00")
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="flex justify-end px-6 pb-4 pt-3 shrink-0 border-t border-gray-100 dark:border-gray-700">
    <button type="button" onclick="closeModal()" aria-label="Close"
            class="px-4 py-2 text-sm rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700">
        Close
    </button>
</div>
</div>
